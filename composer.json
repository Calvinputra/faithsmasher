{
    "name": "calvinputra/faithsmasher",
    "description": "Faith Smasher PHP application",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "monolog/monolog": "^3.0",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "slim/twig-view": "^3.4",
        "twig/twig": "^3.14",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public public/index.php"
    },
    "config": {
        "sort-packages": true
    }
}

{% extends 'layouts/app.twig' %}

{% block title %}{{ app.name }} — Beranda{% endblock %}

{% block content %}
<section class="relative overflow-hidden">
    <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32">
        <div class="mx-auto max-w-3xl text-center">
            <span class="inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-brand-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-100">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
                PHP {{ phpVersion }} · Tailwind CSS
            </span>

            <h1 class="mt-8 text-4xl font-bold tracking-tight text-white sm:text-6xl sm:leading-tight">
                Foundation modern untuk
                <span class="bg-linear-to-r from-brand-100 via-white to-brand-100 bg-clip-text text-transparent">
                    Faith Smasher
                </span>
            </h1>

            <p class="mt-6 text-lg leading-8 text-slate-400 sm:text-xl">
                UI murni Tailwind CSS — tanpa Bootstrap. Routing Slim, template Twig,
                dan styling utility-first yang ringan serta mudah di-custom.
            </p>

            <div id="mulai" class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
                <a
                    href="#fitur"
                    class="w-full rounded-xl bg-brand-600 px-8 py-3.5 text-sm font-semibold text-white shadow-xl shadow-brand-600/30 transition hover:-translate-y-0.5 hover:bg-brand-700 sm:w-auto"
                >
                    Lihat Stack
                </a>
                <a
                    href="https://github.com/Calvinputra/faithsmasher"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full rounded-xl border border-white/10 bg-white/5 px-8 py-3.5 text-sm font-semibold text-slate-200 backdrop-blur-sm transition hover:border-white/20 hover:bg-white/10 sm:w-auto"
                >
                    GitHub Repo
                </a>
            </div>
        </div>
    </div>
</section>

<section id="fitur" class="border-t border-white/10 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="mx-auto mb-14 max-w-2xl text-center">
            <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">Stack & Workflow</h2>
            <p class="mt-4 text-slate-400">Tailwind sebagai satu-satunya CSS framework — modern, fleksibel, tanpa dependency Bootstrap.</p>
        </div>

        <div class="grid gap-6 md:grid-cols-3">
            {% for feature in features %}
                <article class="group rounded-2xl border border-white/10 bg-slate-900/50 p-7 backdrop-blur-sm transition hover:-translate-y-1 hover:border-brand-500/40 hover:shadow-xl hover:shadow-brand-600/10">
                    <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-brand-600/15 text-brand-100 ring-1 ring-brand-500/30">
                        <span class="text-sm font-bold">{{ loop.index }}</span>
                    </div>
                    <h3 class="text-lg font-semibold text-white">{{ feature.title }}</h3>
                    <p class="mt-3 text-sm leading-7 text-slate-400">{{ feature.description }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section id="struktur" class="border-t border-white/10 py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="overflow-hidden rounded-2xl border border-white/10 bg-slate-900/60 backdrop-blur-sm">
            <div class="border-b border-white/10 px-6 py-4 sm:px-8">
                <h2 class="text-xl font-semibold text-white">Struktur Folder</h2>
                <p class="mt-1 text-sm text-slate-400">Source CSS Tailwind ada di <code class="text-brand-100">resources/css/app.css</code></p>
            </div>
            <pre class="overflow-x-auto p-6 text-sm leading-7 text-emerald-300 sm:p-8"><code>faithsmasher/
├── resources/
│   ├── css/app.css       # Source Tailwind (edit di sini)
│   └── views/            # Template Twig
├── public/assets/css/    # Output build Tailwind
├── routes/               # Definisi route
├── src/Controllers/      # Controller
└── storage/              # Log & cache</code></pre>
        </div>
    </div>
</section>
{% endblock %}

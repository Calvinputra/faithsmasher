{% extends 'layouts/app.twig' %}

{% block title %}{{ app.name }} — Home{% endblock %}

{% block content %}
<section class="hero-section">
    <div class="site-container">
        <div class="hero-grid">
            <div class="hero-content">
                <span class="hero-badge">
                    <span class="hero-badge-dot"></span>
                    Badminton Tournament Platform
                </span>
                <h1 class="hero-title">
                    Manage brackets.<br>
                    <span class="hero-title-accent">Track every match.</span>
                </h1>
                <p class="hero-desc">
                    Faith Smashers helps you organize sessions, register players by rank,
                    generate matches, and preview brackets — all in one modern dashboard.
                </p>
                <div class="hero-actions">
                    {% if currentUser %}
                        <a href="/dashboard" class="btn-primary btn-lg">Open Dashboard</a>
                    {% else %}
                        <a href="/register" class="btn-primary btn-lg">Get Started Free</a>
                        <a href="/login" class="btn-secondary btn-lg">Sign In</a>
                    {% endif %}
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-logo-ring">
                    <img src="/assets/images/logo.png" alt="{{ app.name }}" class="hero-logo">
                </div>
            </div>
        </div>
    </div>
</section>

<section id="fitur" class="features-section">
    <div class="site-container">
        <div class="section-header">
            <h2 class="section-title">Everything you need</h2>
            <p class="section-desc">Built for badminton communities who run weekly sessions and tournaments.</p>
        </div>
        <div class="features-grid">
            {% for feature in features %}
                <article class="feature-card">
                    <div class="feature-icon">{{ loop.index }}</div>
                    <h3 class="feature-title">{{ feature.title }}</h3>
                    <p class="feature-text">{{ feature.description }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% set sidebar_session = session %}

{% block title %}{{ session.name }} — {{ app.name }}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <p class="text-xs font-medium text-navy-500 sm:hidden">{{ session.name }}</p>
</div>
{% endblock %}

{% block sidebar_nav %}
    {% include 'components/sidebar.twig' with { session: session, active: 'overview' } %}
{% endblock %}

{% block content %}
{% import 'components/ui/audit-trail.twig' as audit %}
<div class="page-header">
    <div class="min-w-0 space-y-2">
        <span class="session-date-badge inline-flex">{{ session.sessionDate|date('d M Y') }}</span>
        <h1 class="page-title">{{ session.name }}</h1>
        {% if session.location %}
            <p class="session-location">
                {% include 'components/ui/icon.twig' with { name: 'ri-map-pin-line', class: 'shrink-0 text-gold-600', size: 'sm' } %}
                {{ session.location }}
            </p>
        {% endif %}
        <div class="mt-2 max-w-md">
            {{ audit.render(session.createdByName, session.createdAt, session.updatedByName, session.updatedAt, false) }}
        </div>
    </div>
    <div class="flex shrink-0 items-center gap-2">
        <button
            type="button"
            class="btn-secondary"
            data-form-open="session-form-modal"
            data-form-type="session"
            data-form-mode="edit"
            data-form-edit-id="{{ session.id }}"
            data-form-payload="{{ {
                id: session.id,
                name: session.name,
                session_date: session.sessionDate,
                location: session.location,
                court_count: session.courtCount,
                created_by_name: session.createdByName|default(''),
                created_at: session.createdAt,
                updated_by_name: session.updatedByName|default(''),
                updated_at: session.updatedAt|default('')
            }|json_encode|e('html_attr') }}"
        >
            {% include 'components/ui/icon.twig' with { name: 'ri-pencil-line', class: 'mr-2', size: 'sm' } %}
            Edit Session
        </button>
        {% if currentUser.canDelete %}
            {% include 'components/ui/icon-action-delete.twig' with {
                action: '/sessions/' ~ session.id ~ '/delete',
                confirm: 'Hapus session "' ~ session.name ~ '" beserta rules, matches, dan peserta di session ini? (Peserta global tidak dihapus)',
                label: 'Hapus session'
            } %}
        {% endif %}
    </div>
</div>

<div class="stat-grid">
    <div class="stat-card"><p class="stat-label">Participants</p><p class="stat-value">{{ participantCount }}</p></div>
    <div class="stat-card"><p class="stat-label">Courts</p><p class="stat-value">{{ session.courtCount }}</p></div>
    <div class="stat-card"><p class="stat-label">Matches</p><p class="stat-value">{{ matchCount }}</p></div>
    <div class="stat-card"><p class="stat-label">Game Rules</p><p class="stat-value">{{ ruleCount }}</p></div>
</div>

<div class="action-grid">
    <section class="action-card">
        <div class="action-card-header">
            <div class="action-card-icon bg-navy-800 text-gold-400" aria-hidden="true">
                {% include 'components/ui/icon.twig' with { name: 'ri-settings-3-line', size: 'md' } %}
            </div>
            <h2 class="font-bold text-navy-900">Setup Game</h2>
        </div>
        <ul class="action-list">
            <li>{% include 'components/ui/action-link.twig' with { href: '/sessions/' ~ session.id ~ '/participants', label: 'Peserta Session' } %}</li>
            <li>{% include 'components/ui/action-link.twig' with { href: '/participants', label: 'Kelola Peserta Global' } %}</li>
            <li>{% include 'components/ui/action-link.twig' with { href: '/sessions/' ~ session.id ~ '/rules', label: 'Game Rules' } %}</li>
            <li>{% include 'components/ui/action-link.twig' with { href: '/dashboard/' ~ session.id ~ '?modal=session-form-modal&edit=' ~ session.id, label: 'Edit Session' } %}</li>
        </ul>
    </section>
    <section class="action-card">
        <div class="action-card-header">
            <div class="action-card-icon bg-gold-500 text-navy-900" aria-hidden="true">
                {% include 'components/ui/icon.twig' with { name: 'ri-trophy-line', size: 'md' } %}
            </div>
            <h2 class="font-bold text-navy-900">Match</h2>
        </div>
        <ul class="action-list">
            <li>{% include 'components/ui/action-link.twig' with { href: '/sessions/' ~ session.id ~ '/matches', label: 'Match Hub' } %}</li>
            <li>{% include 'components/ui/action-link.twig' with { href: '/sessions/' ~ session.id ~ '/matches/manual', label: 'Manual Setup' } %}</li>
            <li>{% include 'components/ui/action-link.twig' with { href: '/sessions/' ~ session.id ~ '/matches/preview', label: 'Preview Bracket' } %}</li>
            <li>{% include 'components/ui/action-link.twig' with { href: '/sessions/' ~ session.id ~ '/matches/counter', label: 'Player Counter' } %}</li>
        </ul>
    </section>
</div>
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% set active = 'dashboard' %}

{% block title %}Dashboard — {{ app.name }}{% endblock %}

{% block head %}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Dashboard</h1>
    <p class="text-[10px] text-navy-500 sm:hidden">Session & peserta global · shared semua admin</p>
    <p class="hidden text-xs text-navy-500 sm:block">Kelola session turnamen · semua admin (A, B, C, D…) melihat session & peserta global yang sama</p>
</div>
{% endblock %}

{% block content %}
<div class="page-header mb-0 sm:mb-4">
    <div class="w-full sm:hidden">
        <button
            type="button"
            class="btn-primary w-full justify-center"
            data-form-open="session-form-modal"
            data-form-type="session"
            data-form-mode="create"
        >+ Session Baru</button>
    </div>
</div>

{% if stats.sessionCount > 0 %}
    {% include 'components/dashboard/overview-stats.twig' with { stats: stats } %}
{% endif %}

{% include 'components/dashboard/session-toolbar.twig' with {
    search: search,
    date: date|default(''),
    sessionDates: sessionDates|default([]),
    paginator: paginator
} %}

{% if sessions is empty %}
    <div class="empty-state mt-6">
        <div class="empty-state-icon">
            {% include 'components/ui/icon.twig' with { name: 'ri-calendar-event-line', size: 'xl', class: 'text-navy-500' } %}
        </div>
        <h2 class="text-lg font-bold text-navy-900">
            {% if search or date|default('') %}Session tidak ditemukan{% else %}Belum ada session{% endif %}
        </h2>
        <p class="mt-2 text-sm text-navy-600 max-w-xs">
            {% if search or date|default('') %}
                Coba kata kunci lain, tanggal lain, atau reset filter.
            {% else %}
                Buat session pertama untuk mulai menambah peserta dan generate match.
            {% endif %}
        </p>
        {% if search or date|default('') %}
            <a href="/dashboard" class="btn-secondary mt-6 justify-center">Reset Filter</a>
        {% else %}
            <button
                type="button"
                class="btn-primary mt-6 justify-center"
                data-form-open="session-form-modal"
                data-form-type="session"
                data-form-mode="create"
            >Buat Session</button>
        {% endif %}
    </div>
{% else %}
    <div class="session-grid mt-6">
        {% for summary in sessions %}
            {% include 'components/session/card.twig' with { summary: summary } %}
        {% endfor %}
    </div>

    {% set qs = '' %}
    {% if search %}{% set qs = qs ~ 'q=' ~ search|url_encode ~ '&' %}{% endif %}
    {% if date|default('') %}{% set qs = qs ~ 'date=' ~ date|url_encode ~ '&' %}{% endif %}
    <div class="session-list-footer">
        <p class="session-list-footer-text">
            Halaman {{ paginator.page }} dari {{ paginator.totalPages() }}
            · {{ paginator.perPage }} per halaman
        </p>
        {% include 'components/ui/pagination.twig' with {
            paginator: paginator,
            baseUrl: '/dashboard',
            queryString: qs
        } %}
    </div>
{% endif %}
{% endblock %}

{% block scripts %}
<script src="{{ asset('assets/js/dashboard-filter.js') }}" defer></script>
{% endblock %}

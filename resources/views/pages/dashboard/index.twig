{% extends 'layouts/dashboard.twig' %}
{% set active = 'dashboard' %}

{% block title %}Dashboard — {{ app.name }}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Dashboard</h1>
    <p class="hidden text-xs text-navy-500 sm:block">Manage your tournament sessions</p>
</div>
{% endblock %}

{% block content %}
<div class="page-header mb-4 sm:mb-6">
    <div class="w-full sm:hidden">
        <a href="/sessions/create" class="btn-primary w-full justify-center">+ New Session</a>
    </div>
</div>

{% include 'components/ui/search-bar.twig' with { query: search, placeholder: 'Search by name or location...' } %}

{% if search %}
    <p class="mt-3 text-sm text-navy-500">
        {{ paginator.total }} result{{ paginator.total != 1 ? 's' : '' }} for "<strong class="text-navy-800">{{ search }}</strong>"
    </p>
{% else %}
    <p class="mt-3 text-sm text-navy-500">{{ paginator.total }} session{{ paginator.total != 1 ? 's' : '' }} · newest first</p>
{% endif %}

{% if sessions is empty %}
    <div class="empty-state mt-6">
        <div class="empty-state-icon">🏸</div>
        <h2 class="text-lg font-bold text-navy-900">
            {% if search %}No sessions found{% else %}No sessions yet{% endif %}
        </h2>
        <p class="mt-2 text-sm text-navy-600 max-w-xs">
            {% if search %}
                Try a different search term or clear the filter.
            {% else %}
                Create your first session to start adding players and generating matches.
            {% endif %}
        </p>
        {% if search %}
            <a href="/dashboard" class="btn-secondary mt-6 justify-center">Clear Search</a>
        {% else %}
            <a href="/sessions/create" class="btn-primary mt-6 justify-center">Create Session</a>
        {% endif %}
    </div>
{% else %}
    <div class="session-grid mt-6">
        {% for summary in sessions %}
            {% include 'components/session/card.twig' with { summary: summary } %}
        {% endfor %}
    </div>

    {% set qs = search ? 'q=' ~ search|url_encode ~ '&' : '' %}
    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-between">
        <p class="text-sm text-navy-500">
            Page {{ paginator.page }} of {{ paginator.totalPages() }}
            · {{ paginator.total }} total
        </p>
        {% include 'components/ui/pagination.twig' with {
            paginator: paginator,
            baseUrl: '/dashboard',
            queryString: qs
        } %}
    </div>
{% endif %}
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% block title %}Game Rules — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: 'rules' } %}{% endblock %}

{% block topbar_action %}
<button
    type="button"
    class="btn-primary hidden sm:inline-flex px-4 py-2 text-sm"
    data-form-open="rule-form-modal"
    data-form-type="rule"
    data-form-mode="create"
>+ Add Rule</button>
{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Game Rules</h1>
    <p class="hidden text-xs text-navy-500 sm:block">Win / lose point settings</p>
</div>
{% endblock %}

{% block page_modals %}
{% include 'components/rules/form-modal.twig' %}
{% endblock %}

{% block content %}
<div class="page-toolbar mb-4 sm:hidden">
    <div class="page-toolbar-actions w-full">
        <button
            type="button"
            class="btn-primary page-toolbar-btn w-full justify-center"
            data-form-open="rule-form-modal"
            data-form-type="rule"
            data-form-mode="create"
        >+ Add Rule</button>
    </div>
</div>

{% if editRule %}
    <button
        type="button"
        class="hidden"
        data-form-open="rule-form-modal"
        data-form-type="rule"
        data-form-mode="edit"
        data-form-edit-id="{{ editRule.id }}"
        data-form-payload="{{ {
            id: editRule.id,
            name: editRule.name,
            win_points: editRule.winPoints,
            lose_points: editRule.losePoints
        }|json_encode|e('html_attr') }}"
    ></button>
{% endif %}

<div class="grid gap-4 md:grid-cols-2">
    {% for rule in rules %}
        <article class="card">
            <h2 class="font-semibold text-navy-900">{{ rule.name }}</h2>
            <p class="mt-2 text-sm text-navy-600">Win: <strong>{{ rule.winPoints }}</strong> pts · Lose: <strong>{{ rule.losePoints }}</strong> pts</p>
            <div class="mt-4 flex gap-1">
                {% include 'components/ui/icon-action-edit-modal.twig' with {
                    modalId: 'rule-form-modal',
                    formType: 'rule',
                    editId: rule.id,
                    label: 'Edit rule',
                    payload: {
                        id: rule.id,
                        name: rule.name,
                        win_points: rule.winPoints,
                        lose_points: rule.losePoints
                    }
                } %}
                {% if currentUser.canDelete %}
                    {% include 'components/ui/icon-action-delete.twig' with {
                        action: '/sessions/' ~ session.id ~ '/rules/' ~ rule.id ~ '/delete',
                        confirm: 'Delete rule?',
                        label: 'Hapus rule'
                    } %}
                {% endif %}
            </div>
        </article>
    {% else %}
        <div class="card col-span-full py-8 text-center text-navy-500">Belum ada game rules.</div>
    {% endfor %}
</div>
{% endblock %}

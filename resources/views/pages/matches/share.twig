{% extends 'layouts/share.twig' %}
{% block title %}Bagan — {{ session.name }}{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>
{% endblock %}

{% block content %}
<div class="bagan-share-page">
    <div class="bagan-share-toolbar">
        <button type="button" id="bagan-download-btn" class="btn-secondary bagan-share-btn">
            <i class="ri-download-2-line" aria-hidden="true"></i>
            Unduh Gambar
        </button>
        {% if currentUser %}
            <a href="/sessions/{{ session.id }}/matches" class="btn-primary bagan-share-btn" style="text-decoration: none;">
                <i class="ri-edit-2-line" aria-hidden="true"></i>
                Edit Bagan
            </a>
        {% else %}
            <a href="/sessions/{{ session.id }}/matches" class="btn-secondary bagan-share-btn" style="text-decoration: none;">
                <i class="ri-login-box-line" aria-hidden="true"></i>
                Login untuk Edit
            </a>
        {% endif %}
    </div>

    {% if not currentUser %}
        <p class="bagan-share-readonly-note">
            Tampilan publik — hanya lihat & unduh. Centang <strong>Selesai</strong> dan edit bagan hanya untuk admin yang sudah login.
        </p>
    {% endif %}

    <div
        id="bagan-export-root"
        class="bagan-export-root"
        data-filename="{{ exportFilename }}"
        data-can-edit="{{ currentUser ? '1' : '0' }}"
    >
        {% set isShareView = true %}
        {% include 'components/matches/bagan-export-header.twig' %}
        {% include 'components/matches/bagan-sheets.twig' with { isShareView: true } %}
    </div>
</div>
{% endblock %}

{% block scripts %}
<script src="{{ asset('assets/js/bagan-share.js') }}" defer></script>
{% if currentUser %}
<script src="{{ asset('assets/js/bagan-checklist.js') }}" defer></script>
{% endif %}
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% block title %}Preview Bracket — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session } %}{% endblock %}
{% block content %}
<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="text-2xl font-bold text-navy-900">Preview Bracket</h1>
    <a href="/sessions/{{ session.id }}/matches/manual" class="btn-secondary">Edit Manual Setup</a>
</div>

{% if matches is empty %}
    <div class="card text-center py-12 text-navy-500">No matches yet. Auto-generate or set up manually.</div>
{% else %}
    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {% for row in matches %}
            {% set m = row.match %}
            <article class="card {% if m.status == 'bye' %}opacity-75{% endif %}">
                <p class="text-xs font-semibold uppercase text-navy-400">Match {{ m.matchOrder }}</p>
                <div class="mt-3 space-y-2">
                    <div class="rounded-lg bg-navy-50 px-3 py-2 text-sm font-medium text-navy-900">
                        {{ row.p1 ? row.p1.name ~ ' (' ~ row.p1.rank ~ ')' : 'TBD' }}
                    </div>
                    <p class="text-center text-xs text-navy-400">vs</p>
                    <div class="rounded-lg bg-gold-50 px-3 py-2 text-sm font-medium text-navy-900">
                        {{ row.p2 ? row.p2.name ~ ' (' ~ row.p2.rank ~ ')' : (m.status == 'bye' ? 'BYE' : 'TBD') }}
                    </div>
                </div>
                {% set p1c = m.participant1Id ? matchCounts[m.participant1Id]|default(0) : 0 %}
                {% set p2c = m.participant2Id ? matchCounts[m.participant2Id]|default(0) : 0 %}
                {% if p1c > 2 or p2c > 2 %}
                    <p class="mt-2 text-xs font-semibold text-red-600">⚠ Player assigned &gt;2 matches</p>
                {% endif %}
            </article>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}

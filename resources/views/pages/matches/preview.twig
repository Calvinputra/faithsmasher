{% extends 'layouts/dashboard.twig' %}
{% block title %}Preview Bagan — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: 'preview' } %}{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Preview Bagan</h1>
    <p class="hidden text-xs text-navy-500 sm:block">
        {{ baganSettings.baganCount }} bagan ·
        {% if baganSettings.scope == constant('App\\Support\\BaganSettings::SCOPE_GLOBAL') %}
            pairing {{ pairingModes[baganSettings.globalMode]|default(baganSettings.globalMode) }} (global)
        {% else %}
            pairing per bagan
        {% endif %}
    </p>
</div>
{% endblock %}

{% block content %}
<div class="page-toolbar mb-4 sm:mb-6">
    <p class="page-toolbar-meta text-xs text-navy-600 sm:hidden">{{ baganSettings.baganCount }} bagan</p>
    <div class="page-toolbar-actions">
        <a href="/sessions/{{ session.id }}/matches" class="btn-secondary page-toolbar-btn justify-center">Setup Bagan</a>
        <a href="/sessions/{{ session.id }}/matches/manual" class="btn-secondary page-toolbar-btn justify-center">Edit Manual</a>
    </div>
</div>

{% if matches is empty %}
    <div class="card py-12 text-center text-navy-500">
        <p>Belum ada bagan. Atur jumlah bagan & pairing di Match Hub.</p>
        <a href="/sessions/{{ session.id }}/matches" class="btn-primary mt-4 inline-flex">Setup Bagan</a>
    </div>
{% else %}
    <div class="bagan-share-actions card mb-4">
        <div class="bagan-share-actions-row">
            <button type="button" id="bagan-download-btn" class="btn-secondary bagan-share-btn">
                <i class="ri-download-2-line" aria-hidden="true"></i>
                Unduh Gambar
            </button>
            {% if shareToken %}
                <div class="bagan-share-link-wrap">
                    <label for="bagan-share-url" class="sr-only">Link share bagan</label>
                    <input
                        type="text"
                        id="bagan-share-url"
                        class="bagan-share-link-input"
                        value="{{ app.url }}/share/bagan/{{ shareToken }}"
                        readonly
                    >
                    <button type="button" id="bagan-copy-link-btn" class="btn-primary bagan-share-btn">
                        <i class="ri-link" aria-hidden="true"></i>
                        Salin Link Share
                    </button>
                    <a
                        href="{{ app.url }}/share/bagan/{{ shareToken }}"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-secondary bagan-share-btn"
                    >
                        <i class="ri-external-link-line" aria-hidden="true"></i>
                        Buka Link
                    </a>
                </div>
            {% endif %}
        </div>
        <p class="bagan-share-hint">Link share hanya menampilkan bagan (tanpa login & sidebar).</p>
    </div>

    <div
        id="bagan-export-root"
        class="bagan-export-root"
        data-filename="{{ exportFilename }}"
    >
        {% include 'components/matches/bagan-export-header.twig' %}
        {% include 'components/matches/bagan-sheets.twig' %}
    </div>
{% endif %}
{% endblock %}

{% block scripts %}
<script src="{{ asset('assets/js/bagan-share.js') }}" defer></script>
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% block title %}Preview Bagan — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% set active = 'preview' %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: active } %}{% endblock %}

{% block head %}
<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Preview Bagan</h1>
    <p class="hidden text-xs text-navy-500 sm:block">
        {{ baganSettings.baganCount }} bagan ·
        {% if baganSettings.scope == constant('App\\Support\\BaganSettings::SCOPE_GLOBAL') %}
            pairing {{ pairingModes[baganSettings.globalMode]|default(baganSettings.globalMode) }} (global)
        {% else %}
            pairing per bagan
        {% endif %}
    </p>
</div>
{% endblock %}

{% block content %}
{% include 'components/matches/page-toolbar.twig' with {
    session: session,
    meta: baganSettings.baganCount ~ ' bagan',
    hide: 'preview,manual,counter'
} %}

{% if matches is empty %}
    <div class="empty-state">
        <p class="text-navy-600">Belum ada bagan. Atur jumlah bagan & pairing di Match Hub.</p>
        <a href="/sessions/{{ session.id }}/matches" class="btn-primary mt-4 inline-flex justify-center">Setup Bagan</a>
    </div>
{% else %}
    <div class="bagan-share-actions card mb-4">
        <div class="bagan-share-actions-row">
            <button type="button" id="bagan-download-btn" class="btn-secondary bagan-share-btn">
                {% include 'components/ui/icon.twig' with { name: 'ri-download-2-line', size: 'sm' } %}
                Unduh Gambar
            </button>
            {% if shareToken %}
                <div class="bagan-share-link-wrap">
                    <label for="bagan-share-url" class="sr-only">Link share bagan</label>
                    <input
                        type="text"
                        id="bagan-share-url"
                        class="bagan-share-link-input"
                        value="{{ app.url }}/share/bagan/{{ shareToken }}"
                        readonly
                    >
                    <button type="button" id="bagan-copy-link-btn" class="btn-primary bagan-share-btn">
                        {% include 'components/ui/icon.twig' with { name: 'ri-link', size: 'sm' } %}
                        Salin Link Share
                    </button>
                    <a
                        href="{{ app.url }}/share/bagan/{{ shareToken }}"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="btn-secondary bagan-share-btn"
                    >
                        {% include 'components/ui/icon.twig' with { name: 'ri-external-link-line', size: 'sm' } %}
                        Buka Link
                    </a>
                </div>
            {% endif %}
        </div>
        <p class="bagan-share-hint">Link share untuk lihat & unduh bagan. Edit bagan dan centang Selesai hanya untuk admin yang sudah login.</p>
    </div>

    <div
        id="bagan-export-root"
        class="bagan-export-root"
        data-filename="{{ exportFilename }}"
    >
        {% include 'components/matches/bagan-export-header.twig' %}
        {% include 'components/matches/bagan-sheets.twig' %}
    </div>
{% endif %}
{% endblock %}

{% block scripts %}
<script src="{{ asset('assets/js/bagan-share.js') }}" defer></script>
{% endblock %}

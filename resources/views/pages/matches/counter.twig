{% extends 'layouts/dashboard.twig' %}
{% block title %}Player Counter — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session } %}{% endblock %}
{% block content %}
<h1 class="text-2xl font-bold text-navy-900">Player Counter</h1>
<p class="mt-1 text-sm text-navy-600">Total: {{ participants|length }} players</p>

<div class="mt-4 flex flex-wrap gap-2 mb-6">
    {% for rank, count in rankCounts %}
        {% if count > 0 %}
            <span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-semibold text-navy-700">{{ rank }}: {{ count }}</span>
        {% endif %}
    {% endfor %}
</div>

<div class="card overflow-x-auto">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-border text-left text-navy-500">
                <th class="pb-3 pr-4">Name</th>
                <th class="pb-3 pr-4">Rank</th>
                <th class="pb-3 pr-4">Matches Assigned</th>
                <th class="pb-3">Status</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
                {% set count = matchCounts[p.id]|default(0) %}
                <tr class="border-b border-border/60">
                    <td class="py-3 pr-4 font-medium text-navy-900">{{ p.name }}</td>
                    <td class="py-3 pr-4"><span class="rounded bg-gold-100 px-2 py-0.5 text-xs font-bold">{{ p.rank }}</span></td>
                    <td class="py-3 pr-4 text-navy-800 font-semibold">{{ count }}</td>
                    <td class="py-3">
                        {% if count > 2 %}
                            <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-700">Over 2x</span>
                        {% elseif count == 0 %}
                            <span class="text-navy-400 text-xs">Unassigned</span>
                        {% else %}
                            <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700">OK</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="4" class="py-8 text-center text-navy-500">No participants.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% block title %}Player Counter — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% set active = 'counter' %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: active } %}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Player Counter</h1>
    <p class="hidden text-xs text-navy-500 sm:block">{{ session.name }} · {{ participants|length }} peserta · cek frekuensi main</p>
</div>
{% endblock %}

{% block content %}
{% include 'components/matches/page-toolbar.twig' with {
    session: session,
    meta: participants|length ~ ' peserta',
    hide: 'counter'
} %}

{% if rankCounts|default([])|length > 0 %}
<div class="participant-stats mb-3 sm:mb-6">
    <div class="participant-stats-group">
        <span class="participant-stats-label">Rank</span>
        <div class="participant-stats-chips">
            {% for rank, count in rankCounts %}
                {% if count > 0 %}
                    <span class="participant-stat-chip participant-stat-chip-rank">{{ rank }}: {{ count }}</span>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

<div class="card data-table-card overflow-x-auto">
    <table class="w-full text-sm data-table">
        <thead>
            <tr class="border-b border-border text-left text-navy-500">
                <th class="pb-3 pr-4">Nama</th>
                <th class="pb-3 pr-4">Rank</th>
                <th class="pb-3 pr-4">Match</th>
                <th class="pb-3">Status</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
                {% set count = matchCounts[p.id]|default(0) %}
                <tr class="border-b border-border/60">
                    <td class="py-3 pr-4 font-medium text-navy-900">{{ p.name }}</td>
                    <td class="py-3 pr-4"><span class="rounded bg-gold-100 px-2 py-0.5 text-xs font-bold text-navy-800">{{ p.rank }}</span></td>
                    <td class="py-3 pr-4 font-semibold text-navy-800">{{ count }}</td>
                    <td class="py-3">
                        {% if count > 2 %}
                            <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-700">&gt;2x</span>
                        {% elseif count == 0 %}
                            <span class="text-xs text-navy-400">Belum assign</span>
                        {% else %}
                            <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700">OK</span>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                {% include 'components/ui/table-empty.twig' with {
                    colspan: 4,
                    title: 'Belum ada peserta',
                    message: 'Tambahkan peserta ke session terlebih dahulu.'
                } %}
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

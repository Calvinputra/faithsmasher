{% extends 'layouts/dashboard.twig' %}
{% block title %}Match Hub — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% set active = 'matches' %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: active } %}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Match Hub</h1>
    <p class="hidden text-xs text-navy-500 sm:block">{{ participantCount }} peserta · {{ matchCount }} match · {{ baganSettings.baganCount }} bagan (setting)</p>
</div>
{% endblock %}

{% block content %}
<div class="page-toolbar mb-3 sm:mb-6">
    <p class="page-toolbar-meta text-xs text-navy-600 sm:hidden">{{ participantCount }} peserta · {{ matchCount }} match</p>
</div>

<div class="grid gap-3 sm:gap-4 md:grid-cols-2">
    {% include 'components/matches/bagan-setup-form.twig' with {
        session: session,
        participantCount: participantCount,
        baganSettings: baganSettings,
        pairingModes: pairingModes
    } %}

    <article class="card">
        <h2 class="font-semibold text-navy-900">Preview Bagan</h2>
        <p class="mt-2 text-sm text-navy-600">Lihat tabel bagan: pemain, lapangan, urutan main.</p>
        <a href="/sessions/{{ session.id }}/matches/preview" class="btn-secondary mt-4 inline-flex">Buka Preview</a>
    </article>
    <article class="card">
        <h2 class="font-semibold text-navy-900">Manual Setup</h2>
        <p class="mt-2 text-sm text-navy-600">Drag & drop peserta ke slot match setelah generate.</p>
        <a href="/sessions/{{ session.id }}/matches/manual" class="btn-secondary mt-4 inline-flex">Manual Setup</a>
    </article>
    <article class="card">
        <h2 class="font-semibold text-navy-900">Player Counter</h2>
        <p class="mt-2 text-sm text-navy-600">Cek berapa kali setiap pemain main di semua bagan.</p>
        <a href="/sessions/{{ session.id }}/matches/counter" class="btn-secondary mt-4 inline-flex">View Counter</a>
    </article>
</div>
{% endblock %}

{% block scripts %}
<script src="{{ asset('assets/js/bagan-setup.js') }}" defer></script>
{% endblock %}

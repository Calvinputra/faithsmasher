{% extends 'layouts/dashboard.twig' %}
{% set active = 'participants-global' %}
{% block title %}Bulk Upload Peserta Global — {{ app.name }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-3xl">
    <div class="mb-6">
        <a href="/participants" class="inline-flex items-center gap-1 text-sm font-medium text-navy-600 hover:text-navy-900">
            {% include 'components/ui/icon.twig' with { name: 'ri-arrow-left-s-line', size: 'sm' } %}
            Kembali ke Peserta Global
        </a>
        <h1 class="mt-3 text-2xl font-bold text-navy-900 sm:text-3xl">Bulk Upload Peserta Global</h1>
        <p class="mt-1 text-sm text-navy-600">Import ke daftar global — bisa ditambahkan ke session mana saja nanti.</p>
    </div>

    {% include 'components/participants/bulk-format.twig' %}

    <form method="post" action="/participants/bulk" enctype="multipart/form-data" class="card space-y-5">
        {% include 'components/participants/bulk-fields.twig' %}

        <div class="form-actions !border-t-0 !pt-0">
            <button type="submit" class="btn-primary w-full sm:w-auto">
                {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-2', size: 'sm' } %}
                Upload ke Daftar Global
            </button>
            <a href="/participants" class="btn-secondary w-full text-center sm:w-auto">Batal</a>
        </div>
    </form>
</div>
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% set active = 'participants-global' %}
{% block title %}Peserta Global — {{ app.name }}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Peserta Global</h1>
    <p class="hidden text-xs text-navy-500 sm:block">Daftar peserta untuk semua session turnamen</p>
</div>
{% endblock %}

{% block content %}
<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <p class="text-sm text-navy-600">
            <strong>{{ totalCount }}</strong> peserta terdaftar · dipakai ulang di setiap session
        </p>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row">
        <a href="/participants/bulk" class="btn-secondary justify-center">
            {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-2', size: 'sm' } %}
            Bulk Upload
        </a>
        <a href="/participants/create" class="btn-primary justify-center">+ Tambah Peserta</a>
    </div>
</div>

<form method="get" action="/participants" class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-stretch" role="search">
    <div class="search-input-wrap min-w-0 flex-1">
        {% include 'components/ui/icon.twig' with { name: 'ri-search-line', class: 'search-icon' } %}
        <input type="search" name="q" value="{{ search|default('') }}" placeholder="Cari nama, telepon..." class="search-input" autocomplete="off">
    </div>
    <button type="submit" class="btn-secondary search-submit px-4 py-2.5 text-sm whitespace-nowrap">Cari</button>
    {% if search|default('') %}
        <a href="/participants" class="btn-ghost px-4 py-2.5 text-sm whitespace-nowrap">Reset</a>
    {% endif %}
</form>

<div class="mb-6 flex flex-wrap gap-2">
    {% for rank, count in rankCounts %}
        {% if count > 0 %}
            <span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-semibold text-navy-700">{{ rank }}: {{ count }}</span>
        {% endif %}
    {% endfor %}
</div>

<div class="card overflow-x-auto">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-border text-left text-navy-500">
                <th class="pb-3 pr-4">Nama *</th>
                <th class="pb-3 pr-4">Rank *</th>
                <th class="pb-3 pr-4">Gender</th>
                <th class="pb-3 pr-4">Telepon</th>
                <th class="pb-3 pr-4">GMS From</th>
                <th class="pb-3">Aksi</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
                <tr class="border-b border-border/60">
                    <td class="py-3 pr-4 font-medium text-navy-900">{{ p.name }}</td>
                    <td class="py-3 pr-4"><span class="rounded bg-gold-100 px-2 py-0.5 text-xs font-bold text-navy-800">{{ p.rank }}</span></td>
                    <td class="py-3 pr-4 text-navy-600">{{ p.gender ? genders[p.gender]|default(p.gender) : '—' }}</td>
                    <td class="py-3 pr-4 text-navy-600">{{ p.phone|default('—') }}</td>
                    <td class="py-3 pr-4 text-navy-600">{{ p.gmsSource|default('—') }}</td>
                    <td class="py-3 space-x-2 whitespace-nowrap">
                        <a href="/participants/{{ p.id }}/edit" class="text-navy-700 hover:underline">Edit</a>
                        {% if currentUser.canDelete %}
                            <form method="post" action="/participants/{{ p.id }}/delete" class="inline" onsubmit="return confirm('Hapus peserta dari daftar global?')">
                                <button type="submit" class="text-red-600 hover:underline">Hapus</button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="py-10 text-center">
                        <p class="text-navy-500">Belum ada peserta global.</p>
                        <a href="/participants/bulk" class="btn-primary mt-4 inline-flex justify-center">
                            {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-2', size: 'sm' } %}
                            Bulk Upload dari Excel
                        </a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% set active = 'participants-global' %}
{% block title %}Peserta Global — {{ app.name }}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Peserta Global</h1>
    <p class="hidden text-xs text-navy-500 sm:block">Daftar peserta bersama untuk semua admin · klik Rank/Gender/GMS untuk edit cepat</p>
</div>
{% endblock %}

{% block content %}
{% import 'components/ui/audit-trail.twig' as audit %}
<div class="page-toolbar participant-page-toolbar mb-3 sm:mb-6">
    <p class="page-toolbar-meta participant-page-count text-xs text-navy-600 sm:text-sm">
        <span class="sm:hidden"><strong>{{ totalCount }}</strong> peserta · shared</span>
        <span class="hidden sm:inline"><strong>{{ totalCount }}</strong> peserta terdaftar · shared untuk semua session</span>
    </p>
    <div class="page-toolbar-actions participant-page-actions">
        <a href="/participants/bulk" class="btn-secondary page-toolbar-btn participant-page-btn">
            {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-1.5 sm:mr-2', size: 'sm' } %}
            <span class="hidden min-[380px]:inline">Bulk </span>Upload
        </a>
        <button
            type="button"
            class="btn-primary page-toolbar-btn participant-page-btn"
            data-form-open="participant-form-modal"
            data-form-type="participant"
            data-form-mode="create"
        >+ <span class="hidden min-[380px]:inline">Tambah </span>Peserta</button>
    </div>
</div>

{% include 'components/participants/global-filter.twig' %}

<div class="card data-table-card overflow-x-auto">
    <table class="w-full text-sm data-table participants-inline-table">
        <thead>
            <tr class="border-b border-border text-left text-navy-500">
                <th class="pb-3 pr-4">Nama *</th>
                <th class="pb-3 pr-4">Rank *</th>
                <th class="col-hide-sm pb-3 pr-4">Gender</th>
                <th class="col-hide-md pb-3 pr-4">Telepon</th>
                <th class="col-hide-sm pb-3 pr-4">GMS From</th>
                <th class="col-hide-md pb-3 pr-4">Audit</th>
                <th class="pb-3">Aksi</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
                <tr class="border-b border-border/60" data-participant-row="{{ p.id }}">
                    <td class="py-3 pr-4 font-medium text-navy-900">
                        {% include 'components/participants/cell-name.twig' with {
                            name: p.name,
                            gender: p.gender,
                            phone: p.phone,
                            source: p.gmsSource,
                            genders: genders
                        } %}
                        <div class="mt-1 md:hidden">
                            {{ audit.render(p.createdByName, p.createdAt, p.updatedByName, p.updatedAt, true) }}
                        </div>
                    </td>
                    <td class="py-3 pr-4">
                        {% include 'components/participants/inline-field.twig' with {
                            participantId: p.id,
                            field: 'rank',
                            label: 'rank',
                            value: p.rank,
                            display: p.rank,
                            pillClass: 'inline-pill-rank'
                        } %}
                    </td>
                    <td class="col-hide-sm py-3 pr-4">
                        {% include 'components/participants/inline-field.twig' with {
                            participantId: p.id,
                            field: 'gender',
                            label: 'gender',
                            value: p.gender|default(''),
                            display: p.gender ? genders[p.gender]|default(p.gender) : '—',
                            pillClass: p.gender == 'male' ? 'inline-pill-male' : (p.gender == 'female' ? 'inline-pill-female' : 'inline-pill-empty')
                        } %}
                    </td>
                    <td class="col-hide-md py-3 pr-4 text-navy-600">{{ p.phone|default('—') }}</td>
                    <td class="col-hide-sm py-3 pr-4">
                        {% set gmsPill = p.gmsSource ? 'inline-pill-' ~ p.gmsSource|lower : 'inline-pill-empty' %}
                        {% include 'components/participants/inline-field.twig' with {
                            participantId: p.id,
                            field: 'gms_source',
                            label: 'GMS From',
                            value: p.gmsSource|default(''),
                            display: p.gmsSource|default('—'),
                            pillClass: gmsPill
                        } %}
                    </td>
                    <td class="col-hide-md py-3 pr-4">
                        {{ audit.render(p.createdByName, p.createdAt, p.updatedByName, p.updatedAt, true) }}
                    </td>
                    <td class="py-3">
                        <div class="icon-action-group">
                            {% include 'components/ui/icon-action-edit-modal.twig' with {
                                modalId: 'participant-form-modal',
                                formType: 'participant',
                                editId: p.id,
                                label: 'Edit peserta',
                                payload: {
                                    id: p.id,
                                    name: p.name,
                                    rank: p.rank,
                                    gender: p.gender|default(''),
                                    phone: p.phone|default(''),
                                    gms_source: p.gmsSource|default(''),
                                    created_by_name: p.createdByName|default(''),
                                    created_at: p.createdAt,
                                    updated_by_name: p.updatedByName|default(''),
                                    updated_at: p.updatedAt|default('')
                                }
                            } %}
                            {% if currentUser.canDelete %}
                                {% include 'components/ui/icon-action-delete.twig' with {
                                    action: '/participants/' ~ p.id ~ '/delete',
                                    confirm: 'Hapus peserta dari daftar global?',
                                    label: 'Hapus peserta'
                                } %}
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                {% if filter.hasActiveFilters %}
                    {% include 'components/ui/table-empty.twig' with {
                        colspan: 7,
                        title: 'Tidak ada peserta yang cocok',
                        message: 'Coba ubah kata kunci atau reset filter.',
                        resetUrl: '/participants'
                    } %}
                {% else %}
                    {% include 'components/ui/table-empty.twig' with {
                        colspan: 7,
                        icon: 'ri-team-line',
                        title: 'Belum ada peserta global',
                        message: 'Upload bulk atau tambah peserta satu per satu.',
                        actionUrl: '/participants/bulk',
                        actionLabel: 'Bulk Upload dari Excel'
                    } %}
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>

{% if paginator.total > 0 %}
    {% include 'components/ui/list-footer.twig' with {
        paginator: paginator,
        baseUrl: '/participants',
        queryString: filter.paginationQueryString()
    } %}
{% endif %}
{% endblock %}

{% block page_modals %}
{% embed 'components/ui/form-modal.twig' with {
    id: 'participant-form-modal',
    title: 'Tambah Peserta',
    subtitle: 'Data peserta bersama untuk semua admin.',
    formType: 'participant',
    action: '/participants',
    submitLabel: 'Simpan'
} %}
    {% block form_fields %}
        {% include 'components/participants/global-form-fields.twig' %}
    {% endblock %}
{% endembed %}

{% if editParticipant %}
    <button
        type="button"
        class="hidden"
        data-form-open="participant-form-modal"
        data-form-type="participant"
        data-form-mode="edit"
        data-form-edit-id="{{ editParticipant.id }}"
        data-form-payload="{{ {
            id: editParticipant.id,
            name: editParticipant.name,
            rank: editParticipant.rank,
            gender: editParticipant.gender|default(''),
            phone: editParticipant.phone|default(''),
            gms_source: editParticipant.gmsSource|default(''),
            created_by_name: editParticipant.createdByName|default(''),
            created_at: editParticipant.createdAt,
            updated_by_name: editParticipant.updatedByName|default(''),
            updated_at: editParticipant.updatedAt|default('')
        }|json_encode|e('html_attr') }}"
    ></button>
{% endif %}

<div id="inline-edit-menu" class="inline-edit-menu hidden" role="listbox" aria-label="Pilih nilai"></div>
{% endblock %}

{% block scripts %}
<script type="application/json" id="inline-edit-config">
{{ {
    rank: { options: ranks, allowClear: false },
    gender: { options: { male: 'Male', female: 'Female' }, allowClear: true, clearLabel: '— Kosongkan' },
    gms_source: { options: gmsSources, allowClear: true, clearLabel: '— Kosongkan' }
}|json_encode|raw }}
</script>
<script src="{{ asset('assets/js/participants-inline.js') }}" defer></script>
{% endblock %}

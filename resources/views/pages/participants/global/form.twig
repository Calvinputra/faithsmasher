{% extends 'layouts/dashboard.twig' %}
{% set active = 'participants-global' %}
{% block title %}{% if participant %}Edit{% else %}Tambah{% endif %} Peserta — {{ app.name }}{% endblock %}

{% block content %}
<div class="max-w-xl">
    <a href="/participants" class="inline-flex items-center gap-1 text-sm font-medium text-navy-600 hover:text-navy-900">
        {% include 'components/ui/icon.twig' with { name: 'ri-arrow-left-s-line', size: 'sm' } %}
        Kembali ke Peserta Global
    </a>
    <h1 class="mt-3 text-2xl font-bold text-navy-900">{% if participant %}Edit Peserta{% else %}Tambah Peserta{% endif %}</h1>
    <p class="mt-1 text-sm text-navy-600">Data ini bisa dipakai di semua session.</p>

    <form method="post" action="{% if participant %}/participants/{{ participant.id }}{% else %}/participants{% endif %}" class="card mt-6 space-y-4">
        <div>
            <label for="name" class="mb-1.5 block text-sm font-medium text-navy-700">Nama *</label>
            <input type="text" id="name" name="name" required class="input-field" value="{{ old.name|default(participant.name|default('')) }}">
            {% if errors.name is defined %}<p class="mt-1 text-xs text-red-600">{{ errors.name }}</p>{% endif %}
        </div>
        <div>
            <label for="rank" class="mb-1.5 block text-sm font-medium text-navy-700">Rank *</label>
            <select id="rank" name="rank" required class="input-field">
                <option value="">Pilih rank</option>
                {% for value, label in ranks %}
                    <option value="{{ value }}" {% if (old.rank|default(participant.rank|default(''))) == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            {% if errors.rank is defined %}<p class="mt-1 text-xs text-red-600">{{ errors.rank }}</p>{% endif %}
        </div>
        <div>
            <label for="gender" class="mb-1.5 block text-sm font-medium text-navy-700">Gender</label>
            <select id="gender" name="gender" class="input-field">
                <option value="">— Opsional —</option>
                {% for value, label in genders %}
                    <option value="{{ value }}" {% if (old.gender|default(participant.gender|default(''))) == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            {% if errors.gender is defined %}<p class="mt-1 text-xs text-red-600">{{ errors.gender }}</p>{% endif %}
        </div>
        <div>
            <label for="phone" class="mb-1.5 block text-sm font-medium text-navy-700">Telepon</label>
            <input type="text" id="phone" name="phone" class="input-field" value="{{ old.phone|default(participant.phone|default('')) }}">
        </div>
        <div>
            <label for="gms_source" class="mb-1.5 block text-sm font-medium text-navy-700">GMS From</label>
            <select id="gms_source" name="gms_source" class="input-field">
                <option value="">— Opsional —</option>
                {% for value, label in gmsSources|default({}) %}
                    <option value="{{ value }}" {% if (old.gms_source|default(participant.gmsSource|default(''))) == value %}selected{% endif %}>{{ label }}</option>
                {% endfor %}
            </select>
            {% if errors.gms_source is defined %}<p class="mt-1 text-xs text-red-600">{{ errors.gms_source }}</p>{% endif %}
        </div>
        <div class="flex gap-3">
            <button type="submit" class="btn-primary">Simpan</button>
            <a href="/participants" class="btn-secondary">Batal</a>
        </div>
    </form>
</div>
{% endblock %}

{% extends 'layouts/dashboard.twig' %}
{% block title %}Peserta Session — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% set active = 'participants' %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: active } %}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Peserta Session</h1>
    <p class="hidden text-xs text-navy-500 sm:block">{{ session.name }} · {{ totalCount }} peserta · {{ availableCount|default(0) }} belum ditambahkan</p>
</div>
{% endblock %}

{% block content %}
<div class="page-toolbar mb-3 sm:mb-6">
    <p class="page-toolbar-meta text-sm text-navy-600 sm:hidden">{{ session.name }}</p>
    <div class="page-toolbar-actions">
        <a href="/participants" class="btn-ghost page-toolbar-btn justify-center text-sm">Kelola Global</a>
        <a href="/sessions/{{ session.id }}/participants/bulk" class="btn-secondary page-toolbar-btn justify-center">
            {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-1.5 sm:mr-2', size: 'sm' } %}
            <span class="hidden min-[400px]:inline">Import </span>Session
        </a>
        <a href="/sessions/{{ session.id }}/participants/assign" class="btn-primary page-toolbar-btn justify-center">+ Tambah Global</a>
    </div>
</div>

{% if totalCount > 0 %}
    {% include 'components/participants/session-filter.twig' %}
{% endif %}

<div class="card data-table-card overflow-x-auto">
    <table class="w-full text-sm data-table">
        <thead>
            <tr class="border-b border-border text-left text-navy-500">
                <th class="pb-3 pr-4">Nama</th>
                <th class="pb-3 pr-4">Rank</th>
                <th class="col-hide-sm pb-3 pr-4">Gender</th>
                <th class="col-hide-md pb-3 pr-4">No. Telp</th>
                <th class="col-hide-sm pb-3 pr-4">GMS Dari Mana</th>
                <th class="pb-3">Aksi</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
                <tr class="border-b border-border/60">
                    <td class="py-3 pr-4 font-medium text-navy-900">
                        {% include 'components/participants/cell-name.twig' with {
                            name: p.name,
                            gender: p.gender,
                            phone: p.phone,
                            source: p.gmsSource,
                            genders: genders
                        } %}
                    </td>
                    <td class="py-3 pr-4">
                        {% include 'components/ui/badge-rank.twig' with { rank: p.rank } %}
                    </td>
                    <td class="col-hide-sm py-3 pr-4">
                        {% include 'components/ui/badge-gender.twig' with { gender: p.gender, genders: genders } %}
                    </td>
                    <td class="col-hide-md py-3 pr-4 text-navy-600">{{ p.phone|default('—') }}</td>
                    <td class="col-hide-sm py-3 pr-4">
                        {% include 'components/ui/badge-gms.twig' with { source: p.gmsSource } %}
                    </td>
                    <td class="py-3">
                        <div class="icon-action-group">
                            <a href="/participants?edit={{ p.id }}" class="icon-action icon-action-edit" aria-label="Edit peserta" title="Edit peserta">
                                {% include 'components/ui/icon.twig' with { name: 'ri-pencil-line', size: 'sm' } %}
                            </a>
                            {% include 'components/ui/icon-action-remove.twig' with {
                                action: '/sessions/' ~ session.id ~ '/participants/' ~ p.id ~ '/remove',
                                confirm: 'Keluarkan peserta dari session ini?',
                                label: 'Keluarkan dari session'
                            } %}
                        </div>
                    </td>
                </tr>
            {% else %}
                {% if filter.hasActiveFilters|default(false) %}
                    {% include 'components/ui/table-empty.twig' with {
                        colspan: 6,
                        title: 'Tidak ada peserta yang cocok',
                        message: 'Coba ubah filter atau reset.',
                        resetUrl: filter.resetUrl()
                    } %}
                {% else %}
                    {% include 'components/ui/table-empty.twig' with {
                        colspan: 6,
                        title: 'Belum ada peserta di session ini',
                        message: 'Tambah dari daftar global atau buat peserta baru.',
                        actionUrl: '/sessions/' ~ session.id ~ '/participants/assign',
                        actionLabel: 'Tambah dari Global'
                    } %}
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
</div>

{% if paginator.total|default(0) > 0 %}
    {% include 'components/ui/list-footer.twig' with {
        paginator: paginator,
        baseUrl: '/sessions/' ~ session.id ~ '/participants',
        queryString: filter.paginationQueryString()
    } %}
{% endif %}
{% endblock %}

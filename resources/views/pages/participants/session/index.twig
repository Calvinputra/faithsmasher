{% extends 'layouts/dashboard.twig' %}
{% block title %}Peserta Session — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: 'participants' } %}{% endblock %}

{% block content %}
<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <h1 class="text-2xl font-bold text-navy-900">Peserta Session</h1>
        <p class="text-sm text-navy-600">{{ session.name }} — {{ availableCount|default(0) }} peserta global belum ditambahkan ke session ini</p>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row">
        <a href="/participants" class="btn-ghost justify-center text-sm">Kelola Global</a>
        <a href="/sessions/{{ session.id }}/participants/bulk" class="btn-secondary justify-center">
            {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-2', size: 'sm' } %}
            Import ke Session
        </a>
        <a href="/sessions/{{ session.id }}/participants/assign" class="btn-primary justify-center">+ Tambah dari Global</a>
    </div>
</div>

<div class="mb-6 flex flex-wrap gap-2">
    {% for rank, count in rankCounts %}
        {% if count > 0 %}
            <span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-semibold text-navy-700">{{ rank }}: {{ count }}</span>
        {% endif %}
    {% endfor %}
</div>

<div class="card overflow-x-auto">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-border text-left text-navy-500">
                <th class="pb-3 pr-4">Nama</th>
                <th class="pb-3 pr-4">Rank</th>
                <th class="pb-3 pr-4">Gender</th>
                <th class="pb-3 pr-4">Telepon</th>
                <th class="pb-3">Aksi</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
                <tr class="border-b border-border/60">
                    <td class="py-3 pr-4 font-medium text-navy-900">{{ p.name }}</td>
                    <td class="py-3 pr-4"><span class="rounded bg-gold-100 px-2 py-0.5 text-xs font-bold text-navy-800">{{ p.rank }}</span></td>
                    <td class="py-3 pr-4 text-navy-600">{{ p.gender ? genders[p.gender]|default(p.gender) : '—' }}</td>
                    <td class="py-3 pr-4 text-navy-600">{{ p.phone|default('—') }}</td>
                    <td class="py-3">
                        <div class="icon-action-group">
                            {% include 'components/ui/icon-action-edit.twig' with {
                                href: '/participants/' ~ p.id ~ '/edit',
                                label: 'Edit peserta'
                            } %}
                            {% include 'components/ui/icon-action-remove.twig' with {
                                action: '/sessions/' ~ session.id ~ '/participants/' ~ p.id ~ '/remove',
                                confirm: 'Keluarkan peserta dari session ini?',
                                label: 'Keluarkan dari session'
                            } %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="py-10 text-center">
                        <p class="text-navy-500">Belum ada peserta di session ini.</p>
                        <div class="mt-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-center">
                            <a href="/sessions/{{ session.id }}/participants/assign" class="btn-primary inline-flex justify-center">Tambah dari Global</a>
                            <a href="/participants/create" class="btn-secondary inline-flex justify-center">Buat Peserta Global</a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

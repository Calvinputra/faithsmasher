{% extends 'layouts/dashboard.twig' %}
{% block title %}Peserta Session — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: 'participants' } %}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Peserta Session</h1>
    <p class="hidden text-xs text-navy-500 sm:block">{{ session.name }} · {{ participants|length }} peserta · {{ availableCount|default(0) }} belum ditambahkan</p>
</div>
{% endblock %}

{% block content %}
<div class="page-toolbar mb-3 sm:mb-6">
    <p class="page-toolbar-meta text-sm text-navy-600 sm:hidden">{{ session.name }}</p>
    <div class="page-toolbar-actions">
        <a href="/participants" class="btn-ghost page-toolbar-btn justify-center text-sm">Kelola Global</a>
        <a href="/sessions/{{ session.id }}/participants/bulk" class="btn-secondary page-toolbar-btn justify-center">
            {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-1.5 sm:mr-2', size: 'sm' } %}
            <span class="hidden min-[400px]:inline">Import </span>Session
        </a>
        <a href="/sessions/{{ session.id }}/participants/assign" class="btn-primary page-toolbar-btn justify-center">+ Tambah Global</a>
    </div>
</div>

{% if rankCounts|default([])|length > 0 %}
<div class="participant-stats mb-3 sm:mb-6">
    <div class="participant-stats-group">
        <span class="participant-stats-label">Rank</span>
        <div class="participant-stats-chips">
            {% for rank, count in rankCounts %}
                {% if count > 0 %}
                    <span class="participant-stat-chip participant-stat-chip-rank">{{ rank }}: {{ count }}</span>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>
{% endif %}

<div class="card data-table-card overflow-x-auto">
    <table class="w-full text-sm data-table">
        <thead>
            <tr class="border-b border-border text-left text-navy-500">
                <th class="pb-3 pr-4">Nama</th>
                <th class="pb-3 pr-4">Rank</th>
                <th class="col-hide-sm pb-3 pr-4">Gender</th>
                <th class="col-hide-md pb-3 pr-4">Telepon</th>
                <th class="col-hide-sm pb-3 pr-4">GMS</th>
                <th class="pb-3">Aksi</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
                <tr class="border-b border-border/60">
                    <td class="py-3 pr-4 font-medium text-navy-900">
                        {{ p.name }}
                        <div class="mt-1 text-xs text-navy-500 sm:hidden">
                            {% if p.gender %}{{ genders[p.gender]|default(p.gender) }}{% endif %}
                            {% if p.phone %} · {{ p.phone }}{% endif %}
                        </div>
                    </td>
                    <td class="py-3 pr-4"><span class="rounded bg-gold-100 px-2 py-0.5 text-xs font-bold text-navy-800">{{ p.rank }}</span></td>
                    <td class="col-hide-sm py-3 pr-4">
                        {% if p.gender %}
                            <span class="inline-pill {{ p.gender == 'male' ? 'inline-pill-male' : (p.gender == 'female' ? 'inline-pill-female' : 'inline-pill-empty') }}">
                                {{ genders[p.gender]|default(p.gender) }}
                            </span>
                        {% else %}
                            <span class="text-navy-400">—</span>
                        {% endif %}
                    </td>
                    <td class="col-hide-md py-3 pr-4 text-navy-600">{{ p.phone|default('—') }}</td>
                    <td class="col-hide-sm py-3 pr-4">
                        {% if p.gmsSource %}
                            <span class="inline-pill inline-pill-{{ p.gmsSource|lower }}">{{ p.gmsSource }}</span>
                        {% else %}
                            <span class="text-navy-400">—</span>
                        {% endif %}
                    </td>
                    <td class="py-3">
                        <div class="icon-action-group">
                            <a href="/participants?edit={{ p.id }}" class="icon-action icon-action-edit" aria-label="Edit peserta" title="Edit peserta">
                                {% include 'components/ui/icon.twig' with { name: 'ri-pencil-line', size: 'sm' } %}
                            </a>
                            {% include 'components/ui/icon-action-remove.twig' with {
                                action: '/sessions/' ~ session.id ~ '/participants/' ~ p.id ~ '/remove',
                                confirm: 'Keluarkan peserta dari session ini?',
                                label: 'Keluarkan dari session'
                            } %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="py-10 text-center">
                        <p class="text-navy-500">Belum ada peserta di session ini.</p>
                        <div class="mt-4 flex flex-col items-center gap-2 sm:flex-row sm:justify-center">
                            <a href="/sessions/{{ session.id }}/participants/assign" class="btn-primary inline-flex justify-center">Tambah dari Global</a>
                            <a href="/participants?modal=participant-form-modal" class="btn-secondary inline-flex justify-center">Buat Peserta Global</a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

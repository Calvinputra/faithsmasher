{% extends 'layouts/dashboard.twig' %}
{% block title %}Import Peserta — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: 'participants' } %}{% endblock %}

{% block content %}
<div class="mx-auto max-w-3xl">
    <div class="mb-6">
        <a href="/sessions/{{ session.id }}/participants" class="inline-flex items-center gap-1 text-sm font-medium text-navy-600 hover:text-navy-900">
            {% include 'components/ui/icon.twig' with { name: 'ri-arrow-left-s-line', size: 'sm' } %}
            Kembali ke Peserta Session
        </a>
        <h1 class="mt-3 text-2xl font-bold text-navy-900 sm:text-3xl">Import ke Session</h1>
        <p class="mt-1 text-sm text-navy-600">{{ session.name }} — simpan ke global & langsung assign ke session</p>
    </div>

    {% include 'components/participants/bulk-format.twig' %}

    <form method="post" action="/sessions/{{ session.id }}/participants/bulk" enctype="multipart/form-data" class="card space-y-5">
        {% include 'components/participants/bulk-fields.twig' %}

        <div class="bulk-options space-y-3 rounded-xl border border-navy-100 bg-navy-50/60 p-4">
            {% if currentUser.canDelete %}
                <label class="bulk-checkbox">
                    <input type="checkbox" name="replace_existing" value="1" {% if old.replace_existing is defined %}checked{% endif %}>
                    <span>
                        <strong>Ganti peserta di session</strong>
                        <small>Keluarkan semua peserta & hapus match lama di session ini</small>
                    </span>
                </label>
            {% endif %}
            <label class="bulk-checkbox">
                <input type="checkbox" name="generate_matches" value="1" {% if old.generate_matches is defined %}checked{% endif %} checked>
                <span>
                    <strong>Generate match otomatis</strong>
                    <small>Setelah upload, langsung buat match by rank (min. 2 peserta)</small>
                </span>
            </label>
        </div>

        <div class="form-actions !border-t-0 !pt-0">
            <button type="submit" class="btn-primary w-full sm:w-auto">
                {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-2', size: 'sm' } %}
                Import & Assign
            </button>
            <a href="/sessions/{{ session.id }}/participants" class="btn-secondary w-full text-center sm:w-auto">Batal</a>
        </div>
    </form>
</div>
{% endblock %}

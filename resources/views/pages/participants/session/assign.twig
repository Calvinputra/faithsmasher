{% extends 'layouts/dashboard.twig' %}
{% block title %}Tambah Peserta — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: 'participants' } %}{% endblock %}

{% block page_header %}
<div class="min-w-0">
    <h1 class="page-title text-xl sm:text-2xl">Tambah dari Daftar Global</h1>
    <p class="hidden text-xs text-navy-500 sm:block">{{ session.name }} · paste bulk atau centang manual</p>
</div>
{% endblock %}

{% block content %}
<div class="mb-4">
    <a href="/sessions/{{ session.id }}/participants" class="inline-flex items-center gap-1 text-sm font-medium text-navy-600 hover:text-navy-900">
        {% include 'components/ui/icon.twig' with { name: 'ri-arrow-left-s-line', size: 'sm' } %}
        Kembali ke Peserta Session
    </a>
    <p class="mt-2 text-sm text-navy-600 sm:hidden">{{ session.name }}</p>
</div>

{% if pasteErrors|default([])|length > 0 %}
    <div class="mb-4 rounded-xl border border-red-200 bg-red-50 p-4">
        <ul class="list-inside list-disc text-sm text-red-700">
            {% for error in pasteErrors %}
                <li>{{ error }}</li>
            {% endfor %}
        </ul>
    </div>
{% endif %}

{% include 'components/participants/assign-paste.twig' %}

<form method="get" action="/sessions/{{ session.id }}/participants/assign" class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-stretch" role="search">
    <div class="search-input-wrap min-w-0 flex-1">
        {% include 'components/ui/icon.twig' with { name: 'ri-search-line', class: 'search-icon' } %}
        <input type="search" name="q" value="{{ search|default('') }}" placeholder="Cari peserta global..." class="search-input">
    </div>
    <button type="submit" class="btn-secondary px-4 py-2.5 text-sm">Cari</button>
</form>

{% if available is empty %}
    <div class="empty-state">
        <p class="text-navy-600">Semua peserta global sudah ada di session ini, atau belum ada peserta global.</p>
        <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:justify-center">
            <a href="/participants?modal=participant-form-modal" class="btn-primary justify-center">Buat Peserta Global</a>
            <a href="/participants/bulk" class="btn-secondary justify-center">Bulk Upload Global</a>
        </div>
    </div>
{% else %}
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-navy-500">Atau centang manual</p>
    <form method="post" action="/sessions/{{ session.id }}/participants/assign" class="card overflow-hidden">
        <div class="flex flex-col gap-2 border-b border-border bg-navy-50/60 px-3 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-4">
            <p class="text-sm font-semibold text-navy-800">{{ available|length }} peserta tersedia</p>
            <button type="submit" class="btn-primary px-4 py-2 text-sm">Tambahkan ke Session</button>
        </div>
        <div class="overflow-x-auto">
            <table id="assign-participant-table" class="w-full text-sm">
                <thead>
                    <tr class="border-b border-border text-left text-navy-500">
                        <th class="w-10 px-3 py-2"></th>
                        <th class="px-3 py-2">Nama</th>
                        <th class="px-3 py-2">Rank</th>
                        <th class="px-3 py-2">Gender</th>
                        <th class="px-3 py-2">No. Telp</th>
                        <th class="px-3 py-2">GMS Dari Mana</th>
                    </tr>
                </thead>
                <tbody>
                    {% for p in available %}
                        <tr
                            class="border-b border-border/60 hover:bg-navy-50/40"
                            data-participant-name="{{ p.name|lower }}"
                        >
                            <td class="px-3 py-2">
                                <input type="checkbox" name="participant_ids[]" value="{{ p.id }}" class="h-4 w-4 rounded border-navy-200 text-gold-500 focus:ring-gold-400">
                            </td>
                            <td class="px-3 py-2 font-medium text-navy-900">{{ p.name }}</td>
                            <td class="px-3 py-2"><span class="rounded bg-gold-100 px-2 py-0.5 text-xs font-bold">{{ p.rank }}</span></td>
                            <td class="px-3 py-2">
                                {% if p.gender %}
                                    <span class="inline-pill {{ p.gender == 'male' ? 'inline-pill-male' : (p.gender == 'female' ? 'inline-pill-female' : 'inline-pill-empty') }}">
                                        {{ genders[p.gender]|default(p.gender) }}
                                    </span>
                                {% else %}
                                    <span class="text-navy-400">—</span>
                                {% endif %}
                            </td>
                            <td class="px-3 py-2 text-navy-600">{{ p.phone|default('—') }}</td>
                            <td class="px-3 py-2">
                                {% if p.gmsSource %}
                                    <span class="inline-pill inline-pill-{{ p.gmsSource|lower }}">{{ p.gmsSource }}</span>
                                {% else %}
                                    <span class="text-navy-400">—</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="border-t border-border px-3 py-3 sm:px-4">
            <button type="submit" class="btn-primary w-full justify-center sm:w-auto">Tambahkan ke Session</button>
        </div>
    </form>
{% endif %}
{% endblock %}

{% block scripts %}
<script src="{{ asset('assets/js/assign-paste.js') }}" defer></script>
{% endblock %}

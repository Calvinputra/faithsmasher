{% extends 'layouts/dashboard.twig' %}
{% block title %}Participants — {{ session.name }}{% endblock %}
{% set sidebar_session = session %}
{% block sidebar_nav %}{% include 'components/sidebar.twig' with { session: session, active: 'participants' } %}{% endblock %}
{% block content %}
<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
        <h1 class="text-2xl font-bold text-navy-900">Participants</h1>
        <p class="text-sm text-navy-600">{{ session.name }} — name & rank required</p>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row">
        <a href="/sessions/{{ session.id }}/participants/bulk" class="btn-secondary justify-center">
            {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-2', size: 'sm' } %}
            Bulk Upload
        </a>
        <a href="/sessions/{{ session.id }}/participants/create" class="btn-primary justify-center">+ Add Participant</a>
    </div>
</div>

<div class="mb-6 flex flex-wrap gap-2">
    {% for rank, count in rankCounts %}
        {% if count > 0 %}
            <span class="rounded-full bg-navy-50 px-3 py-1 text-xs font-semibold text-navy-700">{{ rank }}: {{ count }}</span>
        {% endif %}
    {% endfor %}
</div>

<div class="card overflow-x-auto">
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-border text-left text-navy-500">
                <th class="pb-3 pr-4">Name *</th>
                <th class="pb-3 pr-4">Rank *</th>
                <th class="pb-3 pr-4">Gender</th>
                <th class="pb-3 pr-4">Phone</th>
                <th class="pb-3 pr-4">GMS From</th>
                <th class="pb-3">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for p in participants %}
                <tr class="border-b border-border/60">
                    <td class="py-3 pr-4 font-medium text-navy-900">{{ p.name }}</td>
                    <td class="py-3 pr-4"><span class="rounded bg-gold-100 px-2 py-0.5 text-xs font-bold text-navy-800">{{ p.rank }}</span></td>
                    <td class="py-3 pr-4 text-navy-600">{{ p.gender ? genders[p.gender]|default(p.gender) : '—' }}</td>
                    <td class="py-3 pr-4 text-navy-600">{{ p.phone|default('—') }}</td>
                    <td class="py-3 pr-4 text-navy-600">{{ p.gmsSource|default('—') }}</td>
                    <td class="py-3 space-x-2">
                        <a href="/sessions/{{ session.id }}/participants/{{ p.id }}/edit" class="text-navy-700 hover:underline">Edit</a>
                        {% if currentUser.canDelete %}
                            <form method="post" action="/sessions/{{ session.id }}/participants/{{ p.id }}/delete" class="inline" onsubmit="return confirm('Delete participant?')">
                                <button type="submit" class="text-red-600 hover:underline">Delete</button>
                            </form>
                        {% endif %}
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="py-10 text-center">
                        <p class="text-navy-500">Belum ada peserta.</p>
                        <a href="/sessions/{{ session.id }}/participants/bulk" class="btn-primary mt-4 inline-flex justify-center">
                            {% include 'components/ui/icon.twig' with { name: 'ri-upload-cloud-2-line', class: 'mr-2', size: 'sm' } %}
                            Bulk Upload dari Excel
                        </a>
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

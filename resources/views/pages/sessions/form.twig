{% extends 'layouts/dashboard.twig' %}
{% if session %}{% set sidebar_session = session %}{% endif %}

{% block title %}{% if session %}Edit Session{% else %}New Session{% endif %} — {{ app.name }}{% endblock %}

{% block head %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/airbnb.css">
{% endblock %}

{% block content %}
<div class="mx-auto w-full max-w-lg">
    <div class="mb-6">
        <a href="{% if session %}/dashboard/{{ session.id }}{% else %}/dashboard{% endif %}" class="inline-flex items-center gap-1 text-sm font-medium text-navy-600 hover:text-navy-900">
            {% include 'components/ui/icon.twig' with { name: 'ri-arrow-left-s-line', size: 'sm' } %}
            Back
        </a>
        <h1 class="mt-3 text-2xl font-bold text-navy-900 sm:text-3xl">
            {% if session %}Edit Session{% else %}New Session{% endif %}
        </h1>
        <p class="mt-1 text-sm text-navy-600">Set session name, date, and venue location.</p>
    </div>

    <form
        method="post"
        action="{% if session %}/sessions/{{ session.id }}{% else %}/sessions{% endif %}"
        class="card space-y-5 p-4 sm:p-6"
        id="session-form"
    >
        {# Session Name #}
        <div class="form-group">
            <label for="name" class="form-label">Session Name <span class="text-red-500">*</span></label>
            <div class="input-icon-wrap">
                {% include 'components/ui/icon.twig' with { name: 'ri-price-tag-3-line', class: 'input-icon' } %}
                <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    autocomplete="off"
                    placeholder="e.g. Asuka Weekly"
                    class="input-field input-with-icon{% if errors.name is defined %} input-error{% endif %}"
                    value="{{ old.name|default(session.name|default('')) }}"
                >
            </div>
            {% if errors.name is defined %}<p class="form-error">{{ errors.name }}</p>{% endif %}
        </div>

        {# Session Date — flatpickr #}
        <div class="form-group">
            <label for="session_date" class="form-label">Session Date <span class="text-red-500">*</span></label>
            <div class="input-icon-wrap">
                {% include 'components/ui/icon.twig' with { name: 'ri-calendar-line', class: 'input-icon' } %}
                <input
                    type="text"
                    id="session_date"
                    name="session_date"
                    required
                    placeholder="Select date"
                    readonly
                    class="input-field input-with-icon flatpickr-input{% if errors.session_date is defined %} input-error{% endif %}"
                    value="{{ old.session_date|default(session.sessionDate|default('')) }}"
                >
            </div>
            {% if errors.session_date is defined %}<p class="form-error">{{ errors.session_date }}</p>{% endif %}
        </div>

        {# Location #}
        <div class="form-group">
            <label for="location" class="form-label">Location <span class="text-red-500">*</span></label>
            <div class="input-icon-wrap">
                {% include 'components/ui/icon.twig' with { name: 'ri-map-pin-line', class: 'input-icon' } %}
                <input
                    type="text"
                    id="location"
                    name="location"
                    required
                    autocomplete="off"
                    placeholder="e.g. GMS Arena, Surabaya"
                    class="input-field input-with-icon{% if errors.location is defined %} input-error{% endif %}"
                    value="{{ old.location|default(session.location|default('')) }}"
                >
            </div>
            {% if errors.location is defined %}<p class="form-error">{{ errors.location }}</p>{% endif %}
            <p class="form-hint">Venue or court name where the session takes place.</p>
        </div>

        {# Courts #}
        <div class="form-group">
            <label for="court_count" class="form-label">Number of Courts <span class="text-red-500">*</span></label>
            <div class="input-icon-wrap">
                {% include 'components/ui/icon.twig' with { name: 'ri-building-2-line', class: 'input-icon' } %}
                <input
                    type="number"
                    id="court_count"
                    name="court_count"
                    required
                    min="1"
                    max="99"
                    class="input-field input-with-icon{% if errors.court_count is defined %} input-error{% endif %}"
                    value="{{ old.court_count|default(session.courtCount|default(1)) }}"
                >
            </div>
            {% if errors.court_count is defined %}<p class="form-error">{{ errors.court_count }}</p>{% endif %}
            <p class="form-hint">How many badminton courts are available for this session.</p>
        </div>

        {# Actions — sticky on mobile #}
        <div class="form-actions">
            <button type="submit" class="btn-primary w-full sm:w-auto sm:min-w-[140px]">
                {% if session %}Save Changes{% else %}Create Session{% endif %}
            </button>
            <a href="{% if session %}/dashboard/{{ session.id }}{% else %}/dashboard{% endif %}" class="btn-secondary w-full sm:w-auto text-center">
                Cancel
            </a>
        </div>
    </form>

    {% if session and currentUser.canDelete %}
        <div class="mt-8 flex justify-center border-t border-border pt-6">
            {% include 'components/ui/icon-action-delete.twig' with {
                action: '/sessions/' ~ session.id ~ '/delete',
                confirm: 'Hapus session "' ~ session.name ~ '" beserta rules, matches, dan peserta di session ini? (Peserta global tidak dihapus)',
                label: 'Hapus session'
            } %}
            <span class="ml-2 self-center text-sm text-navy-500">Hapus session &amp; semua data di dalamnya</span>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block sidebar_nav %}
    {% if session %}{% include 'components/sidebar.twig' with { session: session } %}{% endif %}
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="/assets/js/session-form.js"></script>
{% endblock %}

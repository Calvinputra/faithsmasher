{% extends 'layouts/minimal.twig' %}

{% block title %}404 — {{ app.name }}{% endblock %}

{% block content %}
<div class="error-shell">
    <div class="error-card">
        <p class="text-5xl font-extrabold text-gold-500">404</p>
        <h1 class="mt-2 text-xl font-bold text-navy-900 sm:text-2xl">Page not found</h1>
        <p class="mt-2 text-sm text-navy-600">The page you're looking for doesn't exist or has been moved.</p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-center">
            <a href="/dashboard" class="btn-primary justify-center">Dashboard</a>
            <a href="/" class="btn-secondary justify-center">Home</a>
        </div>
    </div>
</div>
{% endblock %}

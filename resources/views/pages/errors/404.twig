{% extends 'layouts/app.twig' %}

{% block title %}404 — {{ app.name }}{% endblock %}

{% block content %}
<section class="flex min-h-[60vh] items-center justify-center px-4 py-16">
    <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand-500">404</p>
        <h1 class="mt-2 text-3xl font-bold text-white sm:text-4xl">Halaman tidak ditemukan</h1>
        <p class="mt-3 text-slate-400">Route yang kamu akses belum ada di aplikasi.</p>
        <a
            href="/"
            class="mt-8 inline-flex rounded-lg bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-700"
        >
            Kembali ke Beranda
        </a>
    </div>
</section>
{% endblock %}

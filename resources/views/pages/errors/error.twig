{% extends 'layouts/minimal.twig' %}

{% block title %}Error — {{ app.name }}{% endblock %}

{% block content %}
<div class="error-shell">
    <div class="error-card">
        <div class="error-icon">
            <svg class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
            </svg>
        </div>
        <h1 class="mt-4 text-xl font-bold text-navy-900 sm:text-2xl">Something went wrong</h1>
        <p class="mt-2 text-sm leading-relaxed text-navy-600">{{ message }}</p>

        {% if debug and exception %}
            <details class="mt-5 rounded-xl border border-border bg-navy-50/50 p-4 text-left">
                <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wider text-navy-600">Debug details</summary>
                <pre class="mt-3 overflow-x-auto text-xs leading-5 text-navy-800">{{ exception.message }}

{{ exception.file }}:{{ exception.line }}</pre>
            </details>
        {% endif %}

        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-center">
            <a href="/dashboard" class="btn-primary justify-center">Back to Dashboard</a>
            <a href="/" class="btn-secondary justify-center">Home</a>
        </div>
    </div>
</div>
{% endblock %}

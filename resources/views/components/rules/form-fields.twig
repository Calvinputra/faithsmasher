<div>
    <label for="rule_form_name" class="form-label">Rule Name *</label>
    <input type="text" id="rule_form_name" name="name" required class="input-field" placeholder="e.g. Standard 21" data-field="name">
    <p class="form-error hidden" data-error-for="name"></p>
</div>
<div class="grid grid-cols-2 gap-4">
    <div>
        <label for="rule_form_win_points" class="form-label">Win Points *</label>
        <input type="number" id="rule_form_win_points" name="win_points" min="0" required class="input-field" data-field="win_points" value="21">
        <p class="form-error hidden" data-error-for="win_points"></p>
    </div>
    <div>
        <label for="rule_form_lose_points" class="form-label">Lose Points *</label>
        <input type="number" id="rule_form_lose_points" name="lose_points" min="0" required class="input-field" data-field="lose_points" value="0">
        <p class="form-error hidden" data-error-for="lose_points"></p>
    </div>
</div>

<div class="sidebar-profile">
    <div class="sidebar-profile-card">
        <div class="sidebar-avatar-wrap">
            <div class="sidebar-avatar" aria-hidden="true">
                {{ currentUser.name|slice(0, 1)|upper }}
            </div>
            <span class="sidebar-avatar-status" title="Online"></span>
        </div>
        <div class="min-w-0 flex-1">
            <p class="sidebar-profile-name">{{ currentUser.name }}</p>
            <p class="sidebar-profile-email">{{ currentUser.email }}</p>
            <span class="sidebar-profile-badge">
                {% if currentUser.isSuperadmin %}Superadmin{% else %}Admin{% endif %}
            </span>
        </div>
    </div>
    <a href="/logout" class="sidebar-logout">
        {% include 'components/ui/icon.twig' with { name: 'ri-logout-box-r-line', class: 'shrink-0' } %}
        Logout
    </a>
</div>

<aside class="dashboard-sidebar hidden lg:flex lg:h-screen lg:w-72 lg:sticky lg:top-0 lg:flex-col">
    <a href="/dashboard" class="sidebar-brand" aria-label="Kembali ke Dashboard">
        <img src="/assets/images/logo.png" alt="" class="sidebar-brand-logo">
        <div class="min-w-0">
            <p class="truncate text-base font-bold text-navy-900">{{ app.name }}</p>
            <p class="sidebar-brand-sub">Tournament Manager</p>
        </div>
    </a>

    <nav class="sidebar-nav flex-1 overflow-y-auto" aria-label="Main navigation">
        <details class="group mb-2" {% if sidebar_session is not defined %}open{% endif %}>
            <summary class="sidebar-section-label flex cursor-pointer list-none select-none items-center justify-between [&::-webkit-details-marker]:hidden">
                <span>Menu Utama</span>
                {% include 'components/ui/icon.twig' with { name: 'ri-arrow-down-s-line', class: 'transition-transform duration-200 group-open:rotate-180' } %}
            </summary>
            <div class="mt-1 space-y-0.5">
                <a href="/dashboard" class="sidebar-link{% if active|default('') == 'dashboard' %} sidebar-link-active{% endif %}"{% if active|default('') == 'dashboard' %} aria-current="page"{% endif %}>
                    {% include 'components/ui/icon.twig' with { name: 'ri-home-4-line', class: 'sidebar-link-icon' } %}
                    <span>Dashboard</span>
                </a>
                <a href="/participants" class="sidebar-link{% if active|default('') == 'participants-global' %} sidebar-link-active{% endif %}"{% if active|default('') == 'participants-global' %} aria-current="page"{% endif %}>
                    {% include 'components/ui/icon.twig' with { name: 'ri-group-line', class: 'sidebar-link-icon' } %}
                    <span>Peserta</span>
                </a>
                {% if currentUser.isSuperadmin %}
                    <a href="/admin/users" class="sidebar-link{% if active|default('') == 'admin-users' %} sidebar-link-active{% endif %}"{% if active|default('') == 'admin-users' %} aria-current="page"{% endif %}>
                        {% include 'components/ui/icon.twig' with { name: 'ri-shield-user-line', class: 'sidebar-link-icon' } %}
                        <span>Kelola User</span>
                    </a>
                {% endif %}
            </div>
        </details>
        {% block sidebar_nav %}{% endblock %}
    </nav>

    {% include 'components/dashboard/sidebar-footer.twig' %}
</aside>

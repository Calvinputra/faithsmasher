{% set settings = baganSettings|default(null) %}
{% set baganCount = settings.baganCount|default(1) %}
{% set scope = settings.scope|default(constant('App\\Support\\BaganSettings::SCOPE_GLOBAL')) %}
{% set globalMode = settings.globalMode|default('rank') %}
{% set perModes = settings.perBaganModes|default([globalMode]) %}

<article class="card bagan-setup-card md:col-span-2 shadow-sm border border-navy-100 p-0 overflow-hidden">
    <div class="bagan-setup-header border-b border-navy-50 bg-white p-5 sm:p-6">
        <div>
            <h2 class="text-lg font-bold text-navy-900 tracking-tight">Setup & Generate Bagan</h2>
            <p class="mt-1.5 text-sm text-navy-600">
                Setiap bagan = 1 kesempatan main untuk semua peserta. Format: <strong>A & B vs C & D</strong>.
                Jumlah match per bagan sama: <strong>ceil(peserta ÷ 4)</strong> (contoh 20 → 5 match, 21 → 6 match).
                Partner max 1×, lawan max 2× — rank disamakan sejauh mungkin.
            </p>
        </div>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-gold-50 px-3 py-1 text-xs font-bold text-gold-700 ring-1 ring-gold-200">
            <i class="ri-map-pin-line"></i> {{ session.courtCount }} lapangan
        </span>
    </div>

    <form
        method="post"
        action="/sessions/{{ session.id }}/matches/generate"
        class="bagan-setup-form bg-white p-5 sm:p-6"
        id="bagan-setup-form"
        data-no-nav
    >
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-2 pb-6">
            <div class="form-group">
                <label for="bagan_count" class="form-label text-navy-800 font-semibold mb-2 block">Jumlah bagan</label>
                <input
                    type="number"
                    id="bagan_count"
                    name="bagan_count"
                    class="input-field w-full sm:w-2/3"
                    min="1"
                    max="20"
                    value="{{ baganCount }}"
                    required
                >
                <p class="form-hint mt-2">Contoh: 6 bagan = setiap pemain main 6 kali.</p>
            </div>

            <div class="form-group">
                <span class="form-label text-navy-800 font-semibold mb-2 block">Mode pairing</span>
                <div class="inline-flex w-full rounded-full bg-navy-100 p-1 sm:w-auto">
                    <label class="flex-1 cursor-pointer sm:flex-none">
                        <input
                            type="radio"
                            name="bagan_pairing_scope"
                            value="{{ constant('App\\Support\\BaganSettings::SCOPE_GLOBAL') }}"
                            {% if scope == constant('App\\Support\\BaganSettings::SCOPE_GLOBAL') %}checked{% endif %}
                            class="peer sr-only"
                            data-bagan-scope-toggle
                        >
                        <span class="flex items-center justify-center whitespace-nowrap rounded-full px-5 py-2 text-sm font-semibold text-navy-600 transition-all hover:text-navy-900 peer-checked:bg-white peer-checked:text-navy-900 peer-checked:shadow-sm peer-checked:ring-1 peer-checked:ring-black/5 sm:px-8">
                            Global
                        </span>
                    </label>
                    <label class="flex-1 cursor-pointer sm:flex-none">
                        <input
                            type="radio"
                            name="bagan_pairing_scope"
                            value="{{ constant('App\\Support\\BaganSettings::SCOPE_PER_BAGAN') }}"
                            {% if scope == constant('App\\Support\\BaganSettings::SCOPE_PER_BAGAN') %}checked{% endif %}
                            class="peer sr-only"
                            data-bagan-scope-toggle
                        >
                        <span class="flex items-center justify-center whitespace-nowrap rounded-full px-5 py-2 text-sm font-semibold text-navy-600 transition-all hover:text-navy-900 peer-checked:bg-white peer-checked:text-navy-900 peer-checked:shadow-sm peer-checked:ring-1 peer-checked:ring-black/5 sm:px-8">
                            Per Bagan
                        </span>
                    </label>
                </div>
                <p class="form-hint mt-2.5" data-bagan-scope-hint>
                    {% if scope == constant('App\\Support\\BaganSettings::SCOPE_GLOBAL') %}
                        Semua bagan akan menggunakan aturan yang sama.
                    {% else %}
                        Anda dapat mengatur aturan yang berbeda untuk setiap bagan.
                    {% endif %}
                </p>
            </div>
        </div>

        <div class="border-t border-navy-50 pt-6{% if scope != constant('App\\Support\\BaganSettings::SCOPE_GLOBAL') %} hidden{% endif %}" data-bagan-global-panel>
            <div class="form-group">
                <label for="bagan_pairing_mode" class="form-label text-navy-800 font-semibold mb-2 block">Pairing global (Semua Bagan)</label>
                <select id="bagan_pairing_mode" name="bagan_pairing_mode" class="input-field w-full md:w-1/2" data-search-select>
                    {% for value, label in pairingModes %}
                        <option value="{{ value }}"{% if globalMode == value %} selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>

        <div class="border-t border-navy-50 pt-6{% if scope != constant('App\\Support\\BaganSettings::SCOPE_PER_BAGAN') %} hidden{% endif %}" data-bagan-per-panel>
            <div class="mb-4 flex items-center gap-2">
                <i class="ri-settings-4-line text-navy-500"></i>
                <p class="form-label text-navy-800 font-semibold m-0">Pengaturan Per Bagan</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="bagan-per-grid" data-pairing-modes="{{ pairingModes|json_encode|e('html_attr') }}">
                {% for i in 1..baganCount %}
                    <div class="flex flex-col gap-1.5" data-bagan-per-row>
                        <span class="text-[11px] font-bold uppercase tracking-wider text-navy-500">Bagan {{ i }}</span>
                        <select name="bagan_modes[{{ i }}]" class="input-field bg-white shadow-sm" data-search-select>
                            {% for value, label in pairingModes %}
                                <option value="{{ value }}"{% if (perModes[i - 1]|default(globalMode)) == value %} selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="mt-8 rounded-xl bg-navy-50/70 p-4 sm:p-5 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white shadow-sm text-navy-600">
                    <i class="ri-group-line text-lg"></i>
                </div>
                <div>
                    <p class="text-sm font-bold text-navy-900">{{ participantCount }} Peserta</p>
                    <p class="text-xs text-navy-500 mt-0.5">Tiap bagan akan memainkan ≈ {{ (participantCount / 4)|round(0, 'ceil') }} match ({{ (participantCount / 2)|round(0, 'ceil') }} group)</p>
                </div>
            </div>
            <button 
                type="submit" 
                class="btn-primary w-full shadow-md sm:w-auto sm:px-8" 
                {% if participantCount < 2 %}disabled{% endif %}
                {% if matchCount|default(0) > 0 %}
                    onclick="return confirm('Apakah Anda yakin ingin melakukan generate ulang?\n\nSemua data bagan dan susunan Manual Setup sebelumnya akan ditimpa secara permanen!')"
                {% endif %}
            >
                {% if matchCount|default(0) > 0 %}
                    <i class="ri-refresh-line mr-1.5"></i> Generate Ulang
                {% else %}
                    <i class="ri-flashlight-fill mr-1.5"></i> Generate Bagan
                {% endif %}
            </button>
        </div>
    </form>
</article>

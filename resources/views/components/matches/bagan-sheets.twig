<div class="bagan-preview-stack">
    {% for baganNum, baganMatches in matchesByBagan %}
        {% if baganSettings.scope == constant('App\\Support\\BaganSettings::SCOPE_GLOBAL') %}
            {% set baganMode = baganSettings.globalMode %}
        {% else %}
            {% set baganMode = baganSettings.perBaganModes[baganNum - 1]|default(baganSettings.globalMode) %}
        {% endif %}
        <section class="bagan-preview-section card overflow-hidden p-0">
            <header class="bagan-preview-section-header">
                <h2 class="bagan-preview-title">Bagan {{ baganNum }}</h2>
                <span class="bagan-preview-mode">{{ pairingModes[baganMode]|default(baganMode) }}</span>
            </header>
            <div class="overflow-x-auto">
                <table class="bagan-preview-table w-full text-sm">
                    <thead>
                        <tr>
                            <th>Group</th>
                            <th>Pemain 1</th>
                            <th>Pemain 2</th>
                            <th>Lapangan</th>
                            <th>Urutan Main</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in baganMatches %}
                            {% set m = row.match %}
                            <tr class="{% if m.status == 'bye' %}bagan-row-bye{% endif %}">
                                <td>Group {{ loop.index }}</td>
                                <td class="font-medium text-navy-900">
                                    {{ row.p1 ? row.p1.name : '—' }}
                                    {% if row.p1 %}<span class="bagan-meta">({{ row.p1.rank }})</span>{% endif %}
                                </td>
                                <td class="font-medium text-navy-900">
                                    {{ row.p2 ? row.p2.name : (m.status == 'bye' ? 'BYE' : '—') }}
                                    {% if row.p2 %}<span class="bagan-meta">({{ row.p2.rank }})</span>{% endif %}
                                </td>
                                <td>Lapangan {{ m.courtNumber|default('—') }}</td>
                                <td><span class="bagan-order-badge">{{ m.matchOrder }}</span></td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% endfor %}
</div>

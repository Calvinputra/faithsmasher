<div class="assign-paste-card card mb-4">
    <div class="assign-paste-header">
        <h2 class="flex items-center gap-2 text-base font-bold text-navy-900">
            {% include 'components/ui/icon.twig' with { name: 'ri-clipboard-line', class: 'text-gold-600' } %}
            Paste dari Bulk / Excel
        </h2>
        <p class="mt-1 text-sm text-navy-600">Tempel daftar nama — format sama bulk upload. Hanya peserta yang sudah ada di daftar global.</p>
    </div>

    <form method="post" action="/sessions/{{ session.id }}/participants/assign" class="mt-4 space-y-3">
        <input type="hidden" name="assign_mode" value="paste">
        <label for="bulk_paste" class="form-label">Daftar nama</label>
        <textarea
            id="bulk_paste"
            name="bulk_paste"
            rows="6"
            class="bulk-textarea input-field font-mono text-sm"
            placeholder="Calvin&#10;Yosua,B+&#10;1,Pat,B"
        >{{ old.bulk_paste|default('') }}</textarea>
        <p id="assign-paste-preview" class="hidden text-xs font-medium text-navy-600"></p>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
            <button type="submit" class="btn-primary justify-center sm:w-auto">Tambahkan dari Paste</button>
            <span class="text-xs text-navy-500">Header &amp; kolom rank otomatis dilewati · duplikat di-skip</span>
        </div>
    </form>

    <details class="assign-paste-format mt-4">
        <summary class="cursor-pointer text-sm font-semibold text-navy-700">Format contoh</summary>
        <pre class="bulk-format-example mt-2 text-xs">Calvin
Yosua,B+
1,Pat,B
Kevin,A-</pre>
    </details>
</div>

{# Audit trail — pass createdByName, createdAt, updatedByName, updatedAt, compact (optional) #}
{% macro render(createdByName, createdAt, updatedByName, updatedAt, compact) %}
    {% set creator = createdByName|default('—') %}
    {% set createdLabel = createdAt ? createdAt|date('d M Y, H:i') : '—' %}
    {% set wasUpdated = updatedByName and updatedAt and (updatedByName != createdByName or updatedAt|date('U') != createdAt|date('U')) %}
    {% set isCompact = compact|default(false) %}

    <div class="audit-trail{% if isCompact %} audit-trail-compact{% else %} audit-trail-card{% endif %}" aria-label="Riwayat perubahan">
        {% if not isCompact %}
            <p class="audit-trail-heading">
                {% include 'components/ui/icon.twig' with { name: 'ri-history-line', size: 'sm' } %}
                <span>Riwayat perubahan</span>
            </p>
        {% endif %}

        <div class="audit-trail-items{% if wasUpdated %} audit-trail-items--multi{% endif %}">
            <div class="audit-trail-item">
                <span class="audit-trail-item-icon audit-trail-item-icon-create" aria-hidden="true">
                    {% include 'components/ui/icon.twig' with { name: 'ri-user-add-line', size: 'sm' } %}
                </span>
                <div class="audit-trail-item-body">
                    <span class="audit-trail-item-label">Dibuat</span>
                    <span class="audit-trail-item-user">{{ creator }}</span>
                    <time class="audit-trail-item-time" datetime="{{ createdAt|default('') }}">{{ createdLabel }}</time>
                </div>
            </div>

            {% if wasUpdated %}
                <div class="audit-trail-item">
                    <span class="audit-trail-item-icon audit-trail-item-icon-update" aria-hidden="true">
                        {% include 'components/ui/icon.twig' with { name: 'ri-edit-circle-line', size: 'sm' } %}
                    </span>
                    <div class="audit-trail-item-body">
                        <span class="audit-trail-item-label">Terakhir diupdate</span>
                        <span class="audit-trail-item-user">{{ updatedByName }}</span>
                        <time class="audit-trail-item-time" datetime="{{ updatedAt }}">{{ updatedAt|date('d M Y, H:i') }}</time>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endmacro %}

<form method="get" action="{{ action|default('/dashboard') }}" class="search-bar">
    <div class="search-input-wrap">
        <svg class="search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input
            type="search"
            name="q"
            value="{{ query|default('') }}"
            placeholder="{{ placeholder|default('Search sessions...') }}"
            class="search-input"
            autocomplete="off"
        >
    </div>
    {% if query|default('') %}
        <a href="{{ action|default('/dashboard') }}" class="btn-secondary px-4 py-2.5 text-sm">Clear</a>
    {% endif %}
</form>

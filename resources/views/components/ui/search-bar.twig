<form method="get" action="{{ action|default('/dashboard') }}" class="search-bar" role="search">
    <div class="search-input-wrap">
        {% include 'components/ui/icon.twig' with { name: 'ri-search-line', class: 'search-icon' } %}
        <input
            type="search"
            name="q"
            value="{{ query|default('') }}"
            placeholder="{{ placeholder|default('Cari session, lokasi...') }}"
            class="search-input"
            autocomplete="off"
            aria-label="{{ placeholder|default('Search sessions') }}"
        >
    </div>
    <button type="submit" class="btn-secondary search-submit px-4 py-2.5 text-sm">
        {% include 'components/ui/icon.twig' with { name: 'ri-search-line', class: 'mr-1.5', size: 'sm' } %}
        Cari
    </button>
    {% if query|default('') %}
        <a href="{{ action|default('/dashboard') }}" class="btn-ghost search-clear px-4 py-2.5 text-sm">
            {% include 'components/ui/icon.twig' with { name: 'ri-close-circle-line', class: 'mr-1.5', size: 'sm' } %}
            Reset
        </a>
    {% endif %}
</form>

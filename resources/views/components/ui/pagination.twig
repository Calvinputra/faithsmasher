{% if paginator.hasPages() %}
<nav class="pagination" aria-label="Pagination">
    {% if paginator.hasPrevious() %}
        <a href="{{ baseUrl }}?{{ queryString|default('') }}page={{ paginator.page - 1 }}" class="pagination-btn" aria-label="Halaman sebelumnya">
            {% include 'components/ui/icon.twig' with { name: 'ri-arrow-left-s-line', size: 'sm' } %}
        </a>
    {% else %}
        <span class="pagination-btn pagination-btn-disabled" aria-disabled="true">
            {% include 'components/ui/icon.twig' with { name: 'ri-arrow-left-s-line', size: 'sm' } %}
        </span>
    {% endif %}

    {% for p in paginator.pages() %}
        {% if p == paginator.page %}
            <span class="pagination-num pagination-num-active" aria-current="page">{{ p }}</span>
        {% else %}
            <a href="{{ baseUrl }}?{{ queryString|default('') }}page={{ p }}" class="pagination-num" aria-label="Halaman {{ p }}">{{ p }}</a>
        {% endif %}
    {% endfor %}

    {% if paginator.hasNext() %}
        <a href="{{ baseUrl }}?{{ queryString|default('') }}page={{ paginator.page + 1 }}" class="pagination-btn" aria-label="Halaman berikutnya">
            {% include 'components/ui/icon.twig' with { name: 'ri-arrow-right-s-line', size: 'sm' } %}
        </a>
    {% else %}
        <span class="pagination-btn pagination-btn-disabled" aria-disabled="true">
            {% include 'components/ui/icon.twig' with { name: 'ri-arrow-right-s-line', size: 'sm' } %}
        </span>
    {% endif %}
</nav>
{% endif %}

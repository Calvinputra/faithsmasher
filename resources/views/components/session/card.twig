{% set s = summary.session %}
<article class="session-card">
    <div class="session-card-top">
        <span class="session-date-badge">{{ s.sessionDate|date('d M Y') }}</span>
        {% if summary.participantCount > 0 %}
            <span class="session-active-badge">Aktif</span>
        {% else %}
            <span class="session-draft-badge">Baru</span>
        {% endif %}
    </div>

    <h2 class="session-card-title">{{ s.name }}</h2>

    {% if s.location %}
        <p class="session-location mt-2">
            {% include 'components/ui/icon.twig' with { name: 'ri-map-pin-line', class: 'shrink-0 text-gold-600', size: 'sm' } %}
            <span class="line-clamp-1">{{ s.location }}</span>
        </p>
    {% endif %}

    <div class="session-stats">
        {% include 'components/ui/stat-pill.twig' with {
            value: summary.participantCount,
            label: 'Peserta',
            icon: 'ri-group-line'
        } %}
        {% include 'components/ui/stat-pill.twig' with {
            value: s.courtCount,
            label: 'Lapangan',
            accent: true,
            icon: 'ri-building-2-line'
        } %}
    </div>

    <a href="/dashboard/{{ s.id }}" class="btn-secondary session-card-action mt-4 w-full justify-center text-sm">
        Buka Session
        {% include 'components/ui/icon.twig' with { name: 'ri-arrow-right-s-line', class: 'ml-1', size: 'sm' } %}
    </a>
</article>

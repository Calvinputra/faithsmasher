{% set s = summary.session %}
{% set sessionDay = s.sessionDate|date('Y-m-d') %}
{% set isPastSession = sessionDay < ('now'|date('Y-m-d')) %}
{% import 'components/ui/audit-trail.twig' as audit %}
<article class="session-card{% if isPastSession %} session-card--past{% endif %}">
    <div class="session-card-top">
        <span class="session-date-badge">{{ s.sessionDate|date('d M Y') }}</span>
        <div class="session-card-top-actions">
            {% if isPastSession %}
                <span class="session-past-badge">Selesai</span>
            {% elseif summary.participantCount > 0 %}
                <span class="session-active-badge">Aktif</span>
            {% else %}
                <span class="session-draft-badge">Baru</span>
            {% endif %}
            {% if currentUser.canDelete %}
                {% include 'components/ui/icon-action-delete.twig' with {
                    action: '/sessions/' ~ s.id ~ '/delete',
                    confirm: 'Hapus session "' ~ s.name ~ '" beserta rules, matches, dan peserta di session ini? (Peserta global tidak dihapus)',
                    label: 'Hapus session'
                } %}
            {% endif %}
        </div>
    </div>

    <h2 class="session-card-title">{{ s.name }}</h2>

    {% if s.location %}
        <p class="session-location mt-2">
            {% include 'components/ui/icon.twig' with { name: 'ri-map-pin-line', class: 'shrink-0 text-gold-600', size: 'sm' } %}
            <span class="line-clamp-1">{{ s.location }}</span>
        </p>
    {% endif %}

    <div class="session-card-audit">
        {{ audit.render(s.createdByName, s.createdAt, s.updatedByName, s.updatedAt, true) }}
    </div>

    <div class="session-stats">
        {% include 'components/ui/stat-pill.twig' with {
            value: summary.participantCount,
            label: 'Peserta',
            icon: 'ri-group-line'
        } %}
        {% include 'components/ui/stat-pill.twig' with {
            value: s.courtCount,
            label: 'Lapangan',
            accent: true,
            icon: 'ri-building-2-line'
        } %}
    </div>

    <a href="/dashboard/{{ s.id }}" class="btn-secondary session-card-action mt-4 w-full justify-center text-sm">
        Buka Session
        {% include 'components/ui/icon.twig' with { name: 'ri-arrow-right-s-line', class: 'ml-1', size: 'sm' } %}
    </a>
</article>

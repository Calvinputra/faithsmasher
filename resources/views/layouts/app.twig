<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app.name }}{% endblock %}</title>
    <meta name="description" content="{% block description %}Badminton tournament bracket & score management{% endblock %}">
    {% include 'components/favicon.twig' %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    {% include 'components/remixicon.twig' %}
    <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">
    {% block head %}{% endblock %}
</head>
<body class="min-h-full font-sans antialiased">
    <div class="app-bg"></div>

    <header class="site-header">
        <div class="site-container flex items-center justify-between py-4">
            <a href="/" class="flex items-center gap-3">
                <img src="/assets/images/logo.png" alt="" class="h-10 w-10 rounded-full ring-2 ring-gold-400/40">
                <span class="text-lg font-extrabold text-navy-900">{{ app.name }}</span>
            </a>
            <nav class="hidden items-center gap-6 text-sm font-medium text-navy-600 md:flex">
                <a href="/#fitur" class="hover:text-navy-900 transition">Features</a>
            </nav>
            <div class="flex items-center gap-2">
                {% if currentUser %}
                    <a href="/dashboard" class="btn-primary px-4 py-2 text-sm">Dashboard</a>
                {% else %}
                    <a href="/login" class="btn-ghost hidden sm:inline-flex">Login</a>
                    <a href="/register" class="btn-primary px-4 py-2 text-sm">Get Started</a>
                {% endif %}
            </div>
        </div>
    </header>

    <main>{% block content %}{% endblock %}</main>

    <footer class="site-footer">
        <div class="site-container py-10 text-center text-sm text-navy-500">
            <p>&copy; {{ "now"|date("Y") }} {{ app.name }} · Badminton Tournament Manager</p>
        </div>
    </footer>

    {% include 'components/ui/toast-container.twig' %}
    <script src="/assets/js/app.js"></script>
    <script src="/assets/js/toast.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>

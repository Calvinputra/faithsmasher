<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app.name }}{% endblock %}</title>
    {% include 'components/favicon.twig' %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    {% include 'components/remixicon.twig' %}
    <link rel="stylesheet" href="/assets/css/app.css">
    {% block head %}{% endblock %}
</head>
<body class="min-h-full font-sans antialiased">
    <div class="app-bg"></div>

    <div class="relative flex min-h-full">
        {% embed 'components/dashboard/sidebar.twig' %}
            {% block sidebar_nav %}
                {% if sidebar_session is defined %}
                    {% include 'components/sidebar.twig' with { session: sidebar_session } %}
                {% endif %}
            {% endblock %}
        {% endembed %}

        <div class="flex min-w-0 flex-1 flex-col">
            <header class="dashboard-topbar">
                <div class="flex items-center gap-3 min-w-0">
                    <button type="button" class="mobile-menu-btn lg:hidden" id="mobile-menu-btn" aria-label="Open menu">
                        {% include 'components/ui/icon.twig' with { name: 'ri-menu-line', class: 'text-navy-800', size: 'lg' } %}
                    </button>
                    {% block page_header %}{% endblock %}
                </div>
                <a href="/sessions/create" class="btn-primary hidden sm:inline-flex px-4 py-2 text-sm">
                    + New Session
                </a>
            </header>

            <main class="dashboard-main">
                {% block content %}{% endblock %}
            </main>
        </div>
    </div>

    {# Mobile drawer #}
    <div class="mobile-drawer-overlay hidden" id="mobile-drawer-overlay"></div>
    <aside class="mobile-drawer hidden" id="mobile-drawer">
        <div class="mobile-drawer-header">
            <img src="/assets/images/logo.png" alt="" class="sidebar-brand-logo h-9 w-9">
            <span class="font-bold text-navy-900">{{ app.name }}</span>
            <button type="button" id="mobile-drawer-close" class="ml-auto rounded-lg p-1 text-navy-500 transition hover:bg-navy-50 hover:text-navy-900" aria-label="Close menu">
                {% include 'components/ui/icon.twig' with { name: 'ri-close-line', size: 'lg' } %}
            </button>
        </div>
        <nav class="mobile-drawer-nav flex-1 overflow-y-auto">
            <a href="/dashboard" class="sidebar-link{% if active|default('') == 'dashboard' %} sidebar-link-active{% endif %}">Dashboard</a>
            {% if currentUser.isSuperadmin %}
                <a href="/admin/users" class="sidebar-link{% if active|default('') == 'admin-users' %} sidebar-link-active{% endif %}">Kelola User</a>
            {% endif %}
            {% if sidebar_session is defined %}
                {% include 'components/sidebar.twig' with { session: sidebar_session } %}
            {% endif %}
        </nav>
        {% include 'components/dashboard/sidebar-footer.twig' %}
    </aside>

    {% if sidebar_session is defined %}
        {% include 'components/mobile-nav.twig' with { session: sidebar_session } %}
    {% endif %}

    {% include 'components/ui/toast-container.twig' %}
    <script src="/assets/js/app.js"></script>
    <script src="/assets/js/toast.js"></script>
    <script src="/assets/js/dashboard.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>

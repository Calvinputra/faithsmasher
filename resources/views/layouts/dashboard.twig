<!DOCTYPE html>
<html lang="id" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ app.name }}{% endblock %}</title>
    {% include 'components/favicon.twig' %}
    <script>
        try{if(sessionStorage.getItem('fs-nav'))document.documentElement.classList.add('fs-nav-loading')}catch(e){}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    {% include 'components/remixicon.twig' %}
    <link rel="stylesheet" href="{{ asset('assets/vendor/tom-select/tom-select.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">
    {% block head %}{% endblock %}
</head>
<body class="min-h-full font-sans antialiased">
    <div id="page-progress" class="page-progress" aria-hidden="true"></div>
    <div class="app-bg"></div>

    <div class="relative flex min-h-full">
        {% embed 'components/dashboard/sidebar.twig' %}
            {% block sidebar_nav %}
                {% if sidebar_session is defined %}
                    {% include 'components/sidebar.twig' with { session: sidebar_session } %}
                {% endif %}
            {% endblock %}
        {% endembed %}

        <div class="flex min-w-0 flex-1 flex-col">
            <header class="dashboard-topbar">
                <a href="/dashboard" class="mobile-topbar-brand lg:hidden" aria-label="Kembali ke Dashboard">
                    <img src="{{ asset('assets/images/logo.png') }}" alt="" class="mobile-topbar-logo" width="32" height="32" decoding="async">
                    <span class="mobile-topbar-name">{{ app.name }}</span>
                </a>

                <div class="dashboard-topbar-main min-w-0 flex-1">
                    {% block page_header %}{% endblock %}
                </div>

                <div class="dashboard-topbar-end">
                    {% if sidebar_session is not defined %}
                    <button
                        type="button"
                        class="btn-primary hidden sm:inline-flex px-4 py-2 text-sm lg:inline-flex"
                        data-form-open="session-form-modal"
                        data-form-type="session"
                        data-form-mode="create"
                    >
                        + New Session
                    </button>
                    {% else %}
                        {% block topbar_action %}{% endblock %}
                    {% endif %}
                    <button type="button" class="mobile-menu-btn lg:hidden" id="mobile-menu-btn" aria-label="Buka menu">
                        {% include 'components/ui/icon.twig' with { name: 'ri-menu-line', class: 'text-navy-800', size: 'lg' } %}
                    </button>
                </div>
            </header>

            <main class="dashboard-main">
                {% include 'components/ui/page-skeleton.twig' %}
                <div class="page-content">
                    {% block content %}{% endblock %}
                </div>
            </main>
        </div>
    </div>

    {# Mobile drawer #}
    <div class="mobile-drawer-overlay" id="mobile-drawer-overlay" aria-hidden="true"></div>
    <aside class="mobile-drawer" id="mobile-drawer" aria-hidden="true" aria-label="Menu navigasi">
        <div class="mobile-drawer-header">
            <a href="/dashboard" class="mobile-drawer-brand" aria-label="Kembali ke Dashboard">
                <img src="/assets/images/logo.png" alt="" class="sidebar-brand-logo h-9 w-9" width="36" height="36" decoding="async">
                <span class="font-bold text-navy-900">{{ app.name }}</span>
            </a>
            <button type="button" id="mobile-drawer-close" class="ml-auto rounded-lg p-1 text-navy-500 transition hover:bg-navy-50 hover:text-navy-900" aria-label="Close menu">
                {% include 'components/ui/icon.twig' with { name: 'ri-close-line', size: 'lg' } %}
            </button>
        </div>
        <nav class="mobile-drawer-nav flex-1 overflow-y-auto">
            <a href="/dashboard" class="sidebar-link{% if active|default('') == 'dashboard' %} sidebar-link-active{% endif %}"{% if active|default('') == 'dashboard' %} aria-current="page"{% endif %}>Dashboard</a>
            <a href="/participants" class="sidebar-link{% if active|default('') == 'participants-global' %} sidebar-link-active{% endif %}"{% if active|default('') == 'participants-global' %} aria-current="page"{% endif %}>Peserta</a>
            {% if currentUser.isSuperadmin %}
                <a href="/admin/users" class="sidebar-link{% if active|default('') == 'admin-users' %} sidebar-link-active{% endif %}"{% if active|default('') == 'admin-users' %} aria-current="page"{% endif %}>Kelola User</a>
            {% endif %}
            {% if sidebar_session is defined %}
                {% include 'components/sidebar.twig' with { session: sidebar_session, active: active|default('') } %}
            {% endif %}
        </nav>
        {% include 'components/dashboard/sidebar-footer.twig' %}
    </aside>

    {% if sidebar_session is defined %}
        {% include 'components/mobile-nav.twig' with { session: sidebar_session, active: active|default('') } %}
    {% endif %}

    {% include 'components/ui/toast-container.twig' %}
    {% include 'components/sessions/form-modal.twig' %}
    {% block page_modals %}{% endblock %}
    <script src="{{ asset('assets/vendor/tom-select/tom-select.complete.min.js') }}" defer></script>
    <script src="{{ asset('assets/js/search-select.js') }}" defer></script>
    <script src="{{ asset('assets/js/page-nav.js') }}" defer></script>
    <script src="{{ asset('assets/js/app.js') }}" defer></script>
    <script src="{{ asset('assets/js/toast.js') }}" defer></script>
    <script src="{{ asset('assets/js/modal.js') }}" defer></script>
    <script src="{{ asset('assets/js/flatpickr-loader.js') }}" defer></script>
    <script src="{{ asset('assets/js/form-modal.js') }}" defer></script>
    <script src="{{ asset('assets/js/dashboard.js') }}" defer></script>
    {% block scripts %}{% endblock %}
</body>
</html>
